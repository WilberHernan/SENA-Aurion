<Window x:ConnectionId='1'
    x:Class="VisionaryOptimizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer"
    xmlns:viewmodels="using:VisionaryOptimizer.ViewModels"
    xmlns:models="using:VisionaryOptimizer.Models"
    xmlns:services="using:VisionaryOptimizer.Services"
    Title="Visionary Optimizer">

    <Window.SystemBackdrop>
        <MicaBackdrop /> 
    </Window.SystemBackdrop>

    <Grid x:ConnectionId='2' Background="Transparent" x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- TopBar (32px window title + 52px app menu) = 84px -->
            <RowDefinition Height="*" /> <!-- Content Area -->
            <RowDefinition Height="28" /> <!-- StatusBar -->
        </Grid.RowDefinitions>

        <Viewbox Grid.RowSpan="3" Stretch="UniformToFill" HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0.05">
            <Path Fill="#1DB870" Data="M0,80 C20,30 60,110 100,60 C140,10 180,80 220,40 L220,120 L0,120 Z">
                <Path.RenderTransform>
                    <ScaleTransform ScaleX="10" ScaleY="10" />
                </Path.RenderTransform>
            </Path>
        </Viewbox>

        <!-- 1. BARRA NATIVA CUSTOM FIJA E ÍCONOS DE NAVEGACIÓN SENA -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="52" />
            </Grid.RowDefinitions>

            <!-- Titulo Window Control Standard -->
            <Grid x:ConnectionId='84' x:Name="AppCustomTitleBar" Grid.Row="0" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="8" HorizontalAlignment="Left">
                    <Grid Width="16" Height="16" CornerRadius="8" Background="#1DB870">
                        <FontIcon Glyph="&#xE90C;" FontSize="10" Foreground="#0A0F0D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Sena Aurion" FontSize="13" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold" Foreground="#4DEBA0" />
                </StackPanel>
            </Grid>

            <!-- TABS MENU HORIZONTAL HEADER PILLS -->
            <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="#0FFFFFFF" Background="#0C0A0F0D">
                <Grid Margin="32,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <Line X1="0" Y1="0" X2="0" Y2="24" Stroke="#14FFFFFF" StrokeThickness="1" Margin="8,0" />
                        <Button x:ConnectionId='85' x:Name="TabHome" CommandParameter="home"                         Padding="12,6" Background="Transparent" Foreground="#4DEBA0" BorderThickness="0" CornerRadius="4" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE80F;" FontSize="14" />
                                <TextBlock Text="Inicio" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='86' x:Name="TabInput" CommandParameter="input"                         Padding="12,6" Background="Transparent" Foreground="#4DEBA0" BorderThickness="0" Opacity="0.6" CornerRadius="4" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE144;" FontSize="14" />
                                <TextBlock Text="Input" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='87' x:Name="TabNetwork" CommandParameter="network"                         Padding="12,6" Background="Transparent" Foreground="#4DEBA0" BorderThickness="0" Opacity="0.6" CornerRadius="4" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE701;" FontSize="14" />
                                <TextBlock Text="Network" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='88' x:Name="TabServices" CommandParameter="services"                         Padding="12,6" Background="Transparent" Foreground="#4DEBA0" BorderThickness="0" Opacity="0.6" CornerRadius="4" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                <TextBlock Text="Services" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='89' x:Name="TabCleaner" CommandParameter="cleaner"                         Padding="12,6" Background="Transparent" Foreground="#4DEBA0" BorderThickness="0" Opacity="0.6" CornerRadius="4" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7FC;" FontSize="14" />
                                <TextBlock Text="Cleaner" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Line X1="0" Y1="0" X2="0" Y2="24" Stroke="#14FFFFFF" StrokeThickness="1" Margin="8,0" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                        <Ellipse Width="6" Height="6" Fill="#1DB870" />
                        <TextBlock Text="System Ready" FontSize="12" FontFamily="{StaticResource MonoFont}" Foreground="#1DB870" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 2. CONTENT AREA SIN BLUR-->
        <Grid Grid.Row="1">
                <ScrollViewer x:ConnectionId='3' x:Name="MainScroll" Padding="32" Background="Transparent">
                    <StackPanel Spacing="32" HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="1280" Width="1200" Margin="0,16,0,32">
                        
                        <!-- Panel de Estado Informativo (Movido arriba flotando o a la derecha) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Título General ELIMINADO para no duplicarse por módulo -->
                            
                            <InfoBar x:ConnectionId='83' Grid.Column="1" IsOpen="True" Severity="Informational" Title=""                                                         IsClosable="False" CornerRadius="8" Background="#0F1A14" />
                        </Grid>

                        <!-- INICIO / DASHBOARD -->
                        <StackPanel x:ConnectionId='6' Spacing="32"                                                                             >
                            <StackPanel Spacing="4">
                                <TextBlock Text="DETALLES DEL EQUIPO" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Vista general del entorno y recursos físicos." Style="{StaticResource BodyMutedStyle}"/>
                            </StackPanel>
                            
                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- COLUMNA IZQUIERDA -->
                                <StackPanel Grid.Column="0" Spacing="24">
                                    <!-- 1. EQUIPO -->
                                    <Border x:ConnectionId='70' Style="{StaticResource HomeCardStyle}"                                                                        >
                                        <StackPanel Spacing="24">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Grid Width="40" Height="40" CornerRadius="10" Background="#1A1DB870">
                                                    <FontIcon Glyph="&#xE7F4;" FontSize="18" Foreground="#1DB870" />
                                                </Grid>
                                                <TextBlock Text="INFORMACIÓN DEL EQUIPO" Style="{StaticResource CategoryHeaderStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Spacing="16">
                                                <StackPanel Orientation="Horizontal" Spacing="16" Background="Transparent">
                                                    <TextBlock Text="Hostname:" Style="{StaticResource BodyMutedStyle}" VerticalAlignment="Center" Width="80"/>
                                                    <TextBlock x:ConnectionId='82'                                                               IsTextSelectionEnabled="True" FontFamily="{StaticResource MonoFont}" FontSize="15" Foreground="#F0F4F2" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Line X1="0" Y1="0" X2="2000" Y2="0" Stroke="#0AFFFFFF" StrokeThickness="1" />
                                                <StackPanel Orientation="Horizontal" Spacing="16" Background="Transparent">
                                                    <TextBlock Text="Serial:" Style="{StaticResource BodyMutedStyle}" VerticalAlignment="Center" Width="80"/>
                                                    <TextBlock x:ConnectionId='81'                                                                IsTextSelectionEnabled="True" FontFamily="{StaticResource MonoFont}" FontSize="15" Foreground="#F0F4F2" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Line X1="0" Y1="0" X2="2000" Y2="0" Stroke="#0AFFFFFF" StrokeThickness="1" />
                                                <StackPanel Orientation="Horizontal" Spacing="16" Background="Transparent">
                                                    <TextBlock x:ConnectionId='80'                                                          IsTextSelectionEnabled="True" FontFamily="{StaticResource InterFont}" FontSize="15" Foreground="{StaticResource SenaTextAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="16" Background="Transparent">
                                                    <TextBlock Text="Versión:" Style="{StaticResource BodyMutedStyle}" VerticalAlignment="Center" Width="80"/>
                                                    <TextBlock x:ConnectionId='79'                                                             IsTextSelectionEnabled="True" FontFamily="{StaticResource MonoFont}" FontSize="13" Foreground="#8A9E94" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- 2. CPU -->
                                    <Border x:ConnectionId='71' Style="{StaticResource PremiumCardStyle}"                                                                        >
                                        <StackPanel Spacing="24">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Grid Width="40" Height="40" CornerRadius="10" Background="#1A1DB870">
                                                    <FontIcon Glyph="&#xE968;" FontSize="18" Foreground="#1DB870" />
                                                </Grid>
                                                <TextBlock Text="PROCESADOR (CPU)" Style="{StaticResource CategoryHeaderStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Spacing="8">
                                                <StackPanel Background="Transparent">
                                                    <TextBlock x:ConnectionId='78'                                                            IsTextSelectionEnabled="True" FontFamily="{StaticResource InterFont}" FontSize="18" FontWeight="SemiBold" Foreground="#F0F4F2" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Background="Transparent">
                                                    <TextBlock x:ConnectionId='77'                                                                IsTextSelectionEnabled="True" FontFamily="{StaticResource MonoFont}" FontSize="14" Foreground="{StaticResource SenaTextAccentBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- 3. DISCOS -->
                                    <Border x:ConnectionId='72' Style="{StaticResource PremiumCardStyle}"                                                                        >
                                        <StackPanel Spacing="24">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Grid Width="40" Height="40" CornerRadius="10" Background="#1A1DB870">
                                                    <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="#1DB870" />
                                                </Grid>
                                                <TextBlock Text="ALMACENAMIENTO" Style="{StaticResource CategoryHeaderStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ItemsControl x:ConnectionId='73'                                                               >
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate                                    >
                                                        <Border x:ConnectionId='75' Margin="0,0,0,8" Background="Transparent" Padding="0">
                                                            <TextBlock x:ConnectionId='76'                             IsTextSelectionEnabled="True" FontFamily="{StaticResource InterFont}" FontWeight="Medium" Foreground="#F0F4F2" FontSize="14" TextWrapping="Wrap"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- COLUMNA DERECHA -->
                                <StackPanel Grid.Column="1" Spacing="24">
                                    <!-- 4. RAM -->
                                    <Border x:ConnectionId='61' Style="{StaticResource HomeCardStyle}"                                                                        >
                                        <StackPanel Spacing="24">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Grid Width="40" Height="40" CornerRadius="10" Background="#1A1DB870">
                                                    <FontIcon Glyph="&#xE9A6;" FontSize="18" Foreground="#1DB870" />
                                                </Grid>
                                                <TextBlock Text="MEMORIA RAM" Style="{StaticResource CategoryHeaderStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Spacing="8">
                                                <StackPanel Background="Transparent">
                                                    <TextBlock x:ConnectionId='69'                                                                IsTextSelectionEnabled="True" FontFamily="{StaticResource InterFont}" FontSize="18" FontWeight="SemiBold" Foreground="#F0F4F2" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- 5. GPU -->
                                    <Border x:ConnectionId='62' Style="{StaticResource PremiumCardStyle}"                                                                        >
                                        <StackPanel Spacing="24">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Grid Width="40" Height="40" CornerRadius="10" Background="#1A1DB870">
                                                    <FontIcon Glyph="&#xE7F4;" FontSize="18" Foreground="#1DB870" />
                                                </Grid>
                                                <TextBlock Text="GRÁFICOS (GPU)" Style="{StaticResource CategoryHeaderStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Spacing="8">
                                                <StackPanel Background="Transparent">
                                                    <TextBlock x:ConnectionId='68'                                                            IsTextSelectionEnabled="True" FontFamily="{StaticResource InterFont}" FontSize="18" FontWeight="SemiBold" Foreground="#F0F4F2" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- 6. RED -->
                                    <Border x:ConnectionId='63' Style="{StaticResource PremiumCardStyle}"                                                                        >
                                        <StackPanel Spacing="24">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Grid Width="40" Height="40" CornerRadius="10" Background="#1A1DB870">
                                                    <FontIcon Glyph="&#xE12B;" FontSize="18" Foreground="#1DB870" />
                                                </Grid>
                                                <TextBlock Text="REDES (MAC Address)" Style="{StaticResource CategoryHeaderStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ItemsControl x:ConnectionId='64'                                                                      >
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate                                      >
                                                        <Border x:ConnectionId='66' Margin="0,0,0,8" Background="Transparent" Padding="0">
                                                            <StackPanel Orientation="Horizontal" Spacing="16" Background="Transparent">
                                                                <TextBlock Text="MAC:" Style="{StaticResource BodyMutedStyle}" VerticalAlignment="Center"/>
                                                                <TextBlock x:ConnectionId='67'                             IsTextSelectionEnabled="True" FontSize="14" TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}" Foreground="#F0F4F2" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- SECCIÓN INPUT (RATÓN/TECLADO) -->
                        <StackPanel x:ConnectionId='7' Spacing="24"                                                                              >
                            <StackPanel Spacing="4">
                                <TextBlock Text="INPUT RESPONSE" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Reducción extrema de latencia en periféricos." FontSize="14" FontFamily="{StaticResource InterFont}" Foreground="#C8E6D9" Opacity="0.85"/>
                            </StackPanel>
                            
                            <Border x:ConnectionId='48' Style="{StaticResource PremiumCardStyle}"                                                                        >
                                <StackPanel Spacing="20">
                                    <TextBlock Text="ESTADO EN TIEMPO REAL" Style="{StaticResource CategoryHeaderStyle}" Foreground="#E8F5E9" />
                                    <TextBlock x:ConnectionId='56'                                                       FontSize="15" FontFamily="{StaticResource InterFont}" Foreground="{StaticResource SenaTextAccentBrush}" FontWeight="Medium"/>
                                    
                                    <CheckBox x:ConnectionId='57' Content="SELECCIONAR TODO"                                                            FontFamily="{StaticResource InterFont}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:ConnectionId='58'                                                                                                                                                 Grid.Column="0" Content="APLICAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{StaticResource PrimaryPremiumButton}"                                                         CommandParameter="Input" />
                                        <Button x:ConnectionId='59'                                                                                                                                                                   Grid.Column="1" Content="REVERTIR SELECCIÓN" HorizontalAlignment="Stretch" Style="{StaticResource SecondaryPremiumButton}"                                                          CommandParameter="Input" />
                                        <Button x:ConnectionId='60'                                                                                                                                                                   Grid.Column="2" Content="REVERTIR A FÁBRICA" HorizontalAlignment="Stretch" Style="{StaticResource SecondaryPremiumButton}"                                                     CommandParameter="Input" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:ConnectionId='49'                                                              >
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                                           >
                                        <Border x:ConnectionId='51' Style="{StaticResource PremiumCardStyle}" Padding="16" Margin="0,0,0,12"                                                                        >
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:ConnectionId='52' Grid.Column="0"                                              VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock x:ConnectionId='54'                             FontFamily="{StaticResource InterFont}" FontWeight="Medium" FontSize="14" Foreground="#F0F4F2" VerticalAlignment="Center"/>
                                                        <TextBlock x:ConnectionId='55'                                               FontSize="13" FontFamily="{StaticResource InterFont}" VerticalAlignment="Center" Foreground="{StaticResource SenaTextAccentBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:ConnectionId='53'                             Style="{StaticResource BodyMutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- SECCIÓN RED Y TCP -->
                        <StackPanel x:ConnectionId='8' Spacing="24"                                                                                >
                            <StackPanel Spacing="4">
                                <TextBlock Text="NETWORK &amp; TCP" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Optimiza el protocolo TCP/IP para priorizar el ping en aplicaciones." Style="{StaticResource BodyMutedStyle}"/>
                            </StackPanel>
                            
                            <Border x:ConnectionId='35' Style="{StaticResource PremiumCardStyle}"                                                                        >
                                <StackPanel Spacing="20">
                                    <TextBlock Text="ESTADO EN TIEMPO REAL" Style="{StaticResource CategoryHeaderStyle}" Foreground="#D4944A" />
                                    <TextBlock x:ConnectionId='43'                                                         FontSize="15" FontFamily="{StaticResource InterFont}" Foreground="#D4944A" FontWeight="Medium"/>
                                    
                                    <CheckBox x:ConnectionId='44' Content="SELECCIONAR TODO"                                                              FontFamily="{StaticResource InterFont}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:ConnectionId='45'                                                                                                                                                 Grid.Column="0" Content="APLICAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{StaticResource PrimaryPremiumButton}"                                                         CommandParameter="Network" />
                                        <Button x:ConnectionId='46'                                                                                                                                                                   Grid.Column="1" Content="REVERTIR SELECCIÓN" HorizontalAlignment="Stretch" Style="{StaticResource SecondaryPremiumButton}"                                                          CommandParameter="Network" />
                                        <Button x:ConnectionId='47'                                                                                                                                                                   Grid.Column="2" Content="REVERTIR A FÁBRICA" HorizontalAlignment="Stretch" Style="{StaticResource SecondaryPremiumButton}"                                                     CommandParameter="Network" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:ConnectionId='36'                                                                >
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                                           >
                                        <Border x:ConnectionId='38' Style="{StaticResource PremiumCardStyle}" Padding="16" Margin="0,0,0,12"                                                                        >
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:ConnectionId='39' Grid.Column="0"                                              VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock x:ConnectionId='41'                             FontFamily="{StaticResource InterFont}" FontWeight="Medium" FontSize="14" Foreground="#F0F4F2" VerticalAlignment="Center"/>
                                                        <TextBlock x:ConnectionId='42'                                               FontSize="13" FontFamily="{StaticResource InterFont}" VerticalAlignment="Center" Foreground="{StaticResource SenaTextAccentBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:ConnectionId='40'                             Style="{StaticResource BodyMutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- SECCIÓN SERVICIOS -->
                        <StackPanel x:ConnectionId='9' Spacing="24"                                                                                 >
                            <StackPanel Spacing="4">
                                <TextBlock Text="SERVICIOS" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Desactiva los procesos en segundo plano innecesarios (los críticos están bloqueados si usas Wi-Fi)." Style="{StaticResource BodyMutedStyle}"/>
                            </StackPanel>

                            <Border x:ConnectionId='22' Style="{StaticResource PremiumCardStyle}"                                                                        >
                                <StackPanel Spacing="20">
                                    <TextBlock Text="MODULARIDAD DE SERVICIOS" Style="{StaticResource CategoryHeaderStyle}" Foreground="#8A9E94" />
                                    <TextBlock Text="En lugar de aplicar todo globalmente, puedes mutar solo los servicios elegidos y restaurarlos aquí." Style="{StaticResource BodyMutedStyle}"/>

                                    <CheckBox x:ConnectionId='31' Content="SELECCIONAR TODO"                                                               FontWeight="SemiBold" FontFamily="{StaticResource InterFont}"  Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:ConnectionId='32'                                                                                                                                                 Grid.Column="0" Content="APLICAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{StaticResource PrimaryPremiumButton}"                                                         CommandParameter="Services" />
                                        <Button x:ConnectionId='33'                                                                                                                                                                   Grid.Column="1" Content="REVERTIR SELECCIÓN" HorizontalAlignment="Stretch" Style="{StaticResource SecondaryPremiumButton}"                                                          CommandParameter="Services" />
                                        <Button x:ConnectionId='34'                                                                                                                                                                   Grid.Column="2" Content="REVERTIR A FÁBRICA" HorizontalAlignment="Stretch" Style="{StaticResource SecondaryPremiumButton}"                                                     CommandParameter="Services" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:ConnectionId='23'                                                                >
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                                          >
                                        <Border x:ConnectionId='25' Style="{StaticResource PremiumCardStyle}" Padding="16" Margin="0,0,0,12"                                                                        >
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <CheckBox x:ConnectionId='26' Grid.Column="0"                                                                                                VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                
                                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock x:ConnectionId='29'                             FontFamily="{StaticResource InterFont}" FontWeight="Medium" FontSize="14" Foreground="#F0F4F2" VerticalAlignment="Center"/>
                                                        <TextBlock x:ConnectionId='30'                                               FontSize="12" FontFamily="{StaticResource InterFont}" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource SenaTextAccentBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:ConnectionId='27'                             Style="{StaticResource BodyMutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                                                    <TextBlock x:ConnectionId='28' Text="⚠️ Protegido por conexión Wi-Fi actual" FontFamily="{StaticResource InterFont}"                                                           Foreground="#D4944A" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- SECCIÓN LIMPIEZA -->
                        <StackPanel x:ConnectionId='10' Spacing="24"                                                                                >
                            <StackPanel Spacing="4">
                                <TextBlock Text="LIMPIEZA PROFUNDA" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Elimina datos innecesarios y optimiza el sistema." Style="{StaticResource BodyMutedStyle}"/>
                            </StackPanel>

                            <Border x:ConnectionId='11' Style="{StaticResource PremiumCardStyle}" BorderBrush="#33E05555"                                                                        >
                                <StackPanel Spacing="20">
                                    <TextBlock Text="ZONA DE PELIGRO: ACCIONES DE LIMPIEZA" Style="{StaticResource CategoryHeaderStyle}" Foreground="#E05555" />

                                    <CheckBox x:ConnectionId='20' Content="SELECCIONAR TODO"                                                              FontFamily="{StaticResource InterFont}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:ConnectionId='21'                                                                                                                                                 Grid.Column="0" Content="EJECUTAR LIMPIEZA" HorizontalAlignment="Stretch" Style="{StaticResource PrimaryPremiumButton}" Background="#E05555"                                                         CommandParameter="Cleaner" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:ConnectionId='12'                                                                >
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                                          >
                                        <Border x:ConnectionId='14' Style="{StaticResource PremiumCardStyle}" Padding="16" Margin="0,0,0,12"                                                                        >
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:ConnectionId='15' Grid.Column="0"                                              VerticalAlignment="Center" Margin="0,0,16,0"/>

                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock x:ConnectionId='18'                             FontFamily="{StaticResource InterFont}" FontWeight="Medium" FontSize="15" Foreground="#F0F4F2" VerticalAlignment="Center"/>
                                                        <TextBlock x:ConnectionId='19'                                               FontSize="12" FontFamily="{StaticResource InterFont}" VerticalAlignment="Center" Foreground="{StaticResource SenaTextAccentBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:ConnectionId='16'                             Style="{StaticResource BodyMutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                                                    <!-- Advertencia Roja Crítica -->
                                                    <Border x:ConnectionId='17'                                                       Margin="0,8,0,0" Padding="8" CornerRadius="4" Background="#1AE05555">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE7BA;" Foreground="{StaticResource SenaWarningBrush}" FontSize="14" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ESTA ACCIÓN ELIMINARÁ CARPETAS TEMPORALES DEL ENTORNO ACTUAL." FontFamily="{StaticResource InterFont}" FontWeight="Medium" Foreground="{StaticResource SenaWarningBrush}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- CAPA FLOTANTE MIENTRAS OPTIMIZA (IS BUSY) -->
                <Grid x:ConnectionId='4' Background="#E60A0F0D" 
                                                                                            
                      Canvas.ZIndex="100">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                        <ProgressRing x:ConnectionId='5'                                                   Width="60" Height="60" Foreground="#1DB870" />
                        <TextBlock Text="Inyectando carga de entorno..." FontSize="18" Foreground="#F0F4F2" FontWeight="SemiBold" FontFamily="{StaticResource InterFont}" />
                        <TextBlock Text="Preparando modificaciones nativas" FontSize="14" Foreground="#8A9E94" FontFamily="{StaticResource InterFont}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#0A0F0D" BorderThickness="0,1,0,0" BorderBrush="#14FFFFFF">
            <Grid Margin="32,0">
                <TextBlock Text="Listo para inyectar entorno" VerticalAlignment="Center" Foreground="#8A9E94" FontSize="11" FontFamily="{StaticResource MonoFont}"/>
                <TextBlock Text="v0.1.0-alpha" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#8A9E94" FontSize="11" FontFamily="{StaticResource MonoFont}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

