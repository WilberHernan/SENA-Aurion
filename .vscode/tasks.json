{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build SenaAurion (Debug x64)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/SenaAurion/SenaAurion.csproj",
        "-c",
        "Debug",
        "-p:Platform=x64"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
