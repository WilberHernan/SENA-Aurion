  "networkTcp": {
    "description": "TCP/IP global (HKLM). Aplicar solo elevado; revisar en portátiles con Wi‑Fi si hay efectos en batería.",
    "wifiCriticalServices": [
      "WlanSvc",
      "NlaSvc",
      "Dhcp",
      "Dnscache",
      "BFE",
      "mpssvc"
    ],
    "tweaks": [
      {
        "id": "tcp-ack-frequency",
        "displayName": "TcpAckFrequency",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters\\Interfaces",
        "valueName": "TcpAckFrequency",
        "valueKind": "DWord",
        "valueData": 1,
        "requiresAdmin": true,
        "rationale": "ACKs más frecuentes inyectados en TODAS las interfaces activas de red (Leatrix-style).",
        "sourceAlignment": "Scripts de red / guías gaming",
        "isDanger": true,
        "impactDescription": "Se aplica a cada interfaz TCP/IP. Puede aumentar tráfico de ACK y afectar Wi‑Fi/móvil o escenarios con muchas NIC. Revierte si notas inestabilidad."
      },
      {
        "id": "tcp-no-delay",
        "displayName": "TCPNoDelay",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters\\Interfaces",
        "valueName": "TCPNoDelay",
        "valueKind": "DWord",
        "valueData": 1,
        "requiresAdmin": true,
        "rationale": "Desactiva Nagle (Nagle's Algorithm) bloqueando delay en colas de envío real.",
        "sourceAlignment": "Guías de baja latencia / Esports",
        "isDanger": true,
        "impactDescription": "Afecta a todas las interfaces. Útil en juegos; en transferencias masivas puede cambiar el patrón de paquetes. Comprueba en tu red."
      },
      {
        "id": "tcp-del-ack-ticks",
        "displayName": "TcpDelAckTicks",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters",
        "valueName": "TcpDelAckTicks",
        "valueKind": "DWord",
        "valueData": 0,
        "requiresAdmin": true,
        "rationale": "Retraso diferido de ACK en 0 donde aplica.",
        "sourceAlignment": "Tuning TCP común en scripts"
      },
      {
        "id": "tcp-1323opts",
        "displayName": "Tcp1323Opts",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters",
        "valueName": "Tcp1323Opts",
        "valueKind": "DWord",
        "valueData": 1,
        "requiresAdmin": true,
        "rationale": "RFC 1323 (timestamps / ventana escalada).",
        "sourceAlignment": "Documentación TCP/IP"
      },
      {
        "id": "tcp-default-ttl",
        "displayName": "DefaultTTL",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters",
        "valueName": "DefaultTTL",
        "valueKind": "DWord",
        "valueData": 64,
        "requiresAdmin": true,
        "rationale": "TTL IPv4 conservador frecuente en scripts.",
        "sourceAlignment": "Referencias de tuning"
      },
      {
        "id": "tcp-max-user-port",
        "displayName": "MaxUserPort",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters",
        "valueName": "MaxUserPort",
        "valueKind": "DWord",
        "valueData": 65534,
        "requiresAdmin": true,
        "rationale": "Rango efímero amplio; usado en algunos scripts de servidor/workstation.",
        "sourceAlignment": "Microsoft KB / scripts de rendimiento"
      },
      {
        "id": "tcp-timed-wait-delay",
        "displayName": "TcpTimedWaitDelay",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters",
        "valueName": "TcpTimedWaitDelay",
        "valueKind": "DWord",
        "valueData": 30,
        "requiresAdmin": true,
        "rationale": "Tiempo TIME_WAIT (segundos) reducido en algunos entornos de muchas conexiones.",
        "sourceAlignment": "Scripts avanzados (uso con precaución)",
        "isDanger": true,
        "impactDescription": "Valores bajos pueden causar problemas con sockets en servidores o software que abre muchas conexiones cortas. Revierte ante errores raros de red."
      },
      {
        "id": "tcp-disable-icmp-redirect",
        "displayName": "EnableICMPRedirect (deshabilitar)",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters",
        "valueName": "EnableICMPRedirect",
        "valueKind": "DWord",
        "valueData": 0,
        "requiresAdmin": true,
        "rationale": "Evita seguir redirecciones ICMP para rutas (endurecimiento / estabilidad en algunas redes).",
        "sourceAlignment": "Guías de endurecimiento TCP/IP"
      },
      {
        "id": "tcp-disable-ip-source-routing",
        "displayName": "DisableIPSourceRouting",
        "category": "Network",
        "hive": "LocalMachine",
        "subKey": "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters",
        "valueName": "DisableIPSourceRouting",
        "valueKind": "DWord",
        "valueData": 2,
        "requiresAdmin": true,
        "rationale": "2 = no reenvío de tráfico con opciones de enrutamiento de origen (recomendación de seguridad Microsoft).",
        "sourceAlignment": "Documentación Microsoft / hardening"
      }
    ]
  },
