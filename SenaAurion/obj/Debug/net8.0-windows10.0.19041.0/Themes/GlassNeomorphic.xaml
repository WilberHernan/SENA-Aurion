<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <AcrylicBrush x:Key="GlobalGlassSurfaceBrush" TintColor="#111111" TintOpacity="0.3" FallbackColor="#AA151515" />
    <SolidColorBrush x:Key="NeoButtonFaceBrush" Color="#262626" />
    <SolidColorBrush x:Key="NeoButtonBorderBrush" Color="#26FFFFFF" />

    <Style x:Key="NeoGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource NeoButtonFaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NeoButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Foreground" Value="#E6FFFFFF" />
    </Style>
</ResourceDictionary>

