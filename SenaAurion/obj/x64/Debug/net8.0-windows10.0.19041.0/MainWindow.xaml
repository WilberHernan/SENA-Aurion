<Window x:ConnectionId='1'
    x:Class="VisionaryOptimizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer"
    xmlns:viewmodels="using:VisionaryOptimizer.ViewModels"
    xmlns:models="using:VisionaryOptimizer.Models"
    xmlns:services="using:VisionaryOptimizer.Services"
    Title="Visionary Optimizer">

    <Grid x:ConnectionId='2' x:Name="HostRoot">
        <Image Source="ms-appx:///Assets/Images/bg_splash.jpg" Stretch="UniformToFill" HorizontalAlignment="Right" />
        <Grid HorizontalAlignment="Left" Width="700" IsHitTestVisible="False">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF050C07" Offset="0.0" />
                    <GradientStop Color="#CC050C07" Offset="0.6" />
                    <GradientStop Color="#00050C07" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <Grid x:ConnectionId='3' x:Name="DashboardRoot" MinWidth="600" MinHeight="500" Padding="8" ColumnSpacing="8" Background="Transparent" Visibility="Collapsed">
            <Grid.Resources>
            <!-- Estilos Monocromáticos Premium Dark -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="HomeCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Style x:Key="BodyMutedStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#66FFFFFF" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style x:Key="PrimaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="#2A2A2A" />
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            <Style x:Key="SecondaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="BorderBrush" Value="#1AFFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            
            <!-- Para no crear nuevos estilos complejos y mantener funcionalidad,
                 el texto accent de SENA lo ponemos monocromático aquí. -->
            <SolidColorBrush x:Key="SenaTextAccentBrush" Color="#FFFFFF" />
            </Grid.Resources>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:ConnectionId='17' x:Name="ResponsiveStates">
                <!-- Pantalla Ancha -->
                <VisualState x:ConnectionId='18' x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200"/>
                    </VisualState.StateTriggers>
                </VisualState>
                <!-- Pantalla Mediana -->
                <VisualState x:ConnectionId='19' x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="TabHomeText.Visibility" Value="Collapsed" />
                        <Setter Target="TabInputText.Visibility" Value="Collapsed" />
                        <Setter Target="TabNetworkText.Visibility" Value="Collapsed" />
                        <Setter Target="TabServicesText.Visibility" Value="Collapsed" />
                        <Setter Target="TabCleanerText.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <!-- Pantalla Pequeña -->
                <VisualState x:ConnectionId='20' x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="TabHomeText.Visibility" Value="Collapsed" />
                        <Setter Target="TabInputText.Visibility" Value="Collapsed" />
                        <Setter Target="TabNetworkText.Visibility" Value="Collapsed" />
                        <Setter Target="TabServicesText.Visibility" Value="Collapsed" />
                        <Setter Target="TabCleanerText.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="56" /> <!-- Sidebar Navegación -->
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- BARRA SUPERIOR (TOPBAR) -->
            <Grid x:ConnectionId='27' x:Name="AppCustomTitleBar" Grid.Row="0" Background="#1A1A1A" CornerRadius="14" Height="46">
                <!-- Pills de navegación y Control Central -->
                <Grid Padding="14,0" Background="Transparent">
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="8">
                        <Button x:ConnectionId='74' x:Name="TabHome" CommandParameter="home"                         Background="Transparent" Foreground="#E6FFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:ConnectionId='83' x:Name="TabHomeText" Text="Inicio" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='75' x:Name="TabInput" CommandParameter="input"                         Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:ConnectionId='82' x:Name="TabInputText" Text="Input" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='76' x:Name="TabNetwork" CommandParameter="network"                         Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:ConnectionId='81' x:Name="TabNetworkText" Text="Network" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='77' x:Name="TabServices" CommandParameter="services"                         Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:ConnectionId='80' x:Name="TabServicesText" Text="Services" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='78' x:Name="TabCleaner" CommandParameter="cleaner"                         Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:ConnectionId='79' x:Name="TabCleanerText" Text="Cleaner" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Titulo Central -->
                    <TextBlock Text="SENA AURION" FontSize="13" FontFamily="{StaticResource InterFont}" FontWeight="Bold" Foreground="#80FFFFFF" CharacterSpacing="60" HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- Ícono Derecha -->
                    <Border CornerRadius="14" Width="28" Height="28" BorderThickness="1" BorderBrush="#26FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE90C;" FontSize="12" Foreground="#80FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Grid>

            <!-- AREA DE CONTENIDO -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Border Background="#1A1A1A" CornerRadius="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid x:ConnectionId='28' x:Name="MainContainerContent">
                        <!-- Flecha Salida -->
                        <Border Width="36" Height="36" CornerRadius="18" BorderBrush="#33FFFFFF" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" Canvas.ZIndex="10">
                             <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#99FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- INICIO / DASHBOARD -->
                        <Grid x:ConnectionId='29'                                                                             >
                            <TextBlock Text="INICIO" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="DETALLES DEL EQUIPO" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Vista general del entorno y recursos físicos." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Celda 1 -->
                                        <Border Grid.Column="0" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock x:ConnectionId='73'                                                                FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="RAM" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Celda 2 -->
                                        <Border Grid.Column="1" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock x:ConnectionId='72'                                                                FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="CPU" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Celda 3 -->
                                        <Border Grid.Column="2" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock x:ConnectionId='71'                                                               FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="DISCOS" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Celda 4 -->
                                        <Border Grid.Column="3" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock x:ConnectionId='70'                                                                      FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="REDS" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN INPUT (RATÓN/TECLADO) -->
                        <Grid x:ConnectionId='30'                                                                              >
                            <TextBlock Text="INPUT" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="INPUT RESPONSE" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Reducción extrema de latencia en periféricos." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl x:ConnectionId='64'                                                              >
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate                                           >
                                                    <Grid x:ConnectionId='66' Margin="0,0,0,12">
                                                        <CheckBox x:ConnectionId='67'                                              VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock x:ConnectionId='68'                             FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock x:ConnectionId='69'                                               FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button x:ConnectionId='61'                                                         CommandParameter="Input" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="APLICAMOS SELECCIÓN" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,12,0,0">
                                        <Button x:ConnectionId='62' Content="Revertir"                                                          CommandParameter="Input" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                        <Button x:ConnectionId='63' Content="Fábrica"                                                     CommandParameter="Input" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN RED Y TCP -->
                        <Grid x:ConnectionId='31'                                                                                >
                            <TextBlock Text="NETWORK" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="NETWORK &amp; TCP" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Optimiza el protocolo TCP/IP para priorizar el ping en aplicaciones." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl x:ConnectionId='55'                                                                >
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate                                           >
                                                    <Grid x:ConnectionId='57' Margin="0,0,0,12">
                                                        <CheckBox x:ConnectionId='58'                                              VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock x:ConnectionId='59'                             FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock x:ConnectionId='60'                                               FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button x:ConnectionId='52'                                                         CommandParameter="Network" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="APLICAR RED" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,12,0,0">
                                        <Button x:ConnectionId='53' Content="Revertir"                                                          CommandParameter="Network" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                        <Button x:ConnectionId='54' Content="Fábrica"                                                     CommandParameter="Network" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN SERVICIOS DE WINDOWS -->
                        <Grid x:ConnectionId='32'                                                                                 >
                            <TextBlock Text="SERVICES" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="SERVICIOS DE SISTEMA" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Deshabilita servicios innecesarios que consumen recursos." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl x:ConnectionId='45'                                                                >
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate                                          >
                                                    <Grid x:ConnectionId='47' Margin="0,0,0,12">
                                                        <CheckBox x:ConnectionId='48'                                                                                                VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock x:ConnectionId='49'                             FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock x:ConnectionId='50'                                               FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                            <TextBlock x:ConnectionId='51' Text="⚠️ Protegido Wi-Fi"                                                           Foreground="#D4944A" FontSize="10" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button x:ConnectionId='42'                                                         CommandParameter="Services" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="MUTR SERVICIOS" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,12,0,0">
                                        <Button x:ConnectionId='43' Content="Revertir"                                                          CommandParameter="Services" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                        <Button x:ConnectionId='44' Content="Fábrica"                                                     CommandParameter="Services" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN LIMPIEZA DE WINDOWS -->
                        <Grid x:ConnectionId='33'                                                                                >
                            <TextBlock Text="CLEANER" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="LIMPIEZA DE SISTEMA" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Elimina archivos temporales y basura." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl x:ConnectionId='35'                                                                >
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate                                          >
                                                    <Grid x:ConnectionId='37' Margin="0,0,0,12">
                                                        <CheckBox x:ConnectionId='38'                                              VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock x:ConnectionId='39'                             FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock x:ConnectionId='40'                                               FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                            <TextBlock x:ConnectionId='41' Text="⚠️ ELIMINARÁ CARPETAS"                                                       Foreground="#E05555" FontSize="10" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button x:ConnectionId='34'                                                         CommandParameter="Cleaner" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="EJECUTAR LIMPIEZA" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- COLUMNA DERECHA SECUNDARIA -->
        <Grid Grid.Column="1" RowSpacing="8" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- CARD SUPERIOR -->
            <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="NETWORK STATS" FontSize="13" FontWeight="Bold" Foreground="#D9FFFFFF" />
                    <TextBlock Text="Actividad de red y latencia en ms." FontSize="10" Foreground="#4DFFFFFF" LineHeight="1.5" Margin="0,6,0,10" TextWrapping="Wrap" />
                    
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" Height="40" VerticalAlignment="Bottom" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <!-- Barras minificadas de ejemplo -->
                        <Border Width="8" Height="10" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="25" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="15" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="35" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="20" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="12" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="28" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,16,0,0">
                        <Ellipse Width="6" Height="6" Fill="#CCFFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- CARD INFERIOR -->
            <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="14" Padding="16">
                <StackPanel>
                    <Ellipse Width="64" Height="64" Margin="0,10" Stroke="#1AFFFFFF" StrokeThickness="1" HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3A3A3A" Offset="0"/>
                                <GradientStop Color="#111111" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="OPTIMIZER" FontSize="13" FontWeight="Bold" Foreground="#D9FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Motor listo." FontSize="10" Foreground="#4DFFFFFF" LineHeight="1.5" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SIDEBAR DE NAVEGACIÓN -->
        <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="14">
            <Grid Padding="0,16">
                <!-- Íconos de Navegación Verticalmente Centrados -->
                <StackPanel VerticalAlignment="Center" Spacing="16" HorizontalAlignment="Center">
                    <!-- Home -->
                    <Button x:ConnectionId='21'                         CommandParameter="home" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Inicio">
                        <Grid>
                            <Ellipse Width="36" Height="36" Fill="#2A2A2A" />
                            <FontIcon Glyph="&#xE80F;" FontSize="16" Foreground="#B3FFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Input -->
                    <Button x:ConnectionId='22'                         CommandParameter="input" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Input">
                        <Grid>
                            <FontIcon Glyph="&#xE144;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Network -->
                    <Button x:ConnectionId='23'                         CommandParameter="network" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Network">
                        <Grid>
                            <FontIcon Glyph="&#xE701;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                    
                    <!-- TCP -->
                    <Button x:ConnectionId='24'                         CommandParameter="network" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="TCP">
                        <Grid>
                            <FontIcon Glyph="&#xE968;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Servicios -->
                    <Button x:ConnectionId='25'                         CommandParameter="services" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Servicios">
                        <Grid>
                            <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Cleaner -->
                    <Button x:ConnectionId='26'                         CommandParameter="cleaner" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Limpieza">
                        <Grid>
                            <FontIcon Glyph="&#xE7FC;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        </Grid>

        <Grid x:ConnectionId='4' x:Name="SplashRoot">
            <Grid.Resources>
                <AcrylicBrush x:Key="AcrylicGlassBrush" TintColor="#1A1A1A" TintOpacity="0.2" FallbackColor="#331A1A1A" />
                <Storyboard x:ConnectionId='5' x:Name="ScrollAnimation" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="ScrollTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="14" Duration="0:0:0.9" AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>
            <Grid x:ConnectionId='6' x:Name="UIContainer" RenderTransformOrigin="0.5,0.5">
                <Grid>
                    <Rectangle x:ConnectionId='12' x:Name="AppTitleBar" Height="32" VerticalAlignment="Top" Fill="Transparent"/>
                    <Grid VerticalAlignment="Top" Padding="32,24,32,0" Margin="0,10,0,0">
                        <Path Data="M 18,0 L 36,9 L 36,27 L 18,36 L 0,27 L 0,9 Z M 18,7 A 11,11 0 1 0 18,29 A 11,11 0 1 0 18,7 Z"
                              Stroke="#1DB870" StrokeThickness="2" Fill="Transparent"
                              Width="36" Height="36" Stretch="Uniform"
                              HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Home" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="About" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="Services" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="Contact" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                        </StackPanel>
                        <Button x:ConnectionId='16' Background="Transparent" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="20" Padding="8,7,8,7"
                                HorizontalAlignment="Right" VerticalAlignment="Center"                         Height="42">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Start Page" FontSize="12" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Grid Width="26" Height="26">
                                    <Path Data="M 4,10 L 16,10 M 10,4 L 16,10 L 10,16" Stroke="#FFFFFF" StrokeThickness="1.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="12" Height="12" />
                                </Grid>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,60,0,0">
                        <TextBlock Text="SENA&#x0a;AURION" FontFamily="Segoe UI" FontWeight="ExtraBold" FontSize="72" Foreground="#FFFFFF"
                                   CharacterSpacing="-120" LineStackingStrategy="BlockLineHeight" LineHeight="72" />
                        <TextBlock Text="Where Innovation Knows No Bounds" FontFamily="Segoe UI" FontSize="14"
                                   Foreground="#FFFFFF" Opacity="0.45" Margin="0,10,0,0" CharacterSpacing="30" />
                    </StackPanel>
                    <Button x:ConnectionId='13' Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"                          >
                        <Grid Width="28" Height="44">
                            <Border BorderBrush="#33FFFFFF" BorderThickness="1.5" CornerRadius="14" Background="Transparent" />
                            <Rectangle x:ConnectionId='14' x:Name="ScrollIndicator" Width="4" Height="10" Fill="#80FFFFFF" RadiusX="2" RadiusY="2" VerticalAlignment="Top" Margin="0,6,0,0">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:ConnectionId='15' x:Name="ScrollTransform" Y="0"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="32,0,0,32" Spacing="20">
                        <Image Source="ms-appx:///Assets/Images/facebook.png" Width="18" Height="18" Opacity="0.8" Stretch="Uniform" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid x:ConnectionId='7' x:Name="SpecsModal" Visibility="Collapsed" Padding="24"                                           >
                <Grid.Background>
                    <SolidColorBrush Color="Transparent" />
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid x:ConnectionId='8' Grid.Row="0" HorizontalAlignment="Stretch" Margin="0,24,0,24"                                                  >
                    <TextBlock Text="ESPECIFICACIONES DEL EQUIPO" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Foreground="#D9FFFFFF" CharacterSpacing="50" VerticalAlignment="Center"/>
                    <Button x:ConnectionId='11' FontFamily="Segoe UI" FontSize="14" Width="40" Height="40" Padding="0"
                            Background="#1AFFFFFF" BorderThickness="1" BorderBrush="#33FFFFFF" CornerRadius="20" Foreground="#D9FFFFFF"
                            HorizontalAlignment="Right" VerticalAlignment="Center"                              >
                        <TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
                <TextBlock x:ConnectionId='9' Grid.Row="1" x:Name="SpecsLoadingText" Text="Analizando hardware, por favor espera..." Foreground="#D9FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                <Grid x:ConnectionId='10' Grid.Row="1" x:Name="SpecsContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,0,0,24" Padding="0"                                                                                           />
            </Grid>
        </Grid>
    </Grid>
</Window>

