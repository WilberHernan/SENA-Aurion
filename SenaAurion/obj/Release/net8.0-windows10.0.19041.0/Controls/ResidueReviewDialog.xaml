<UserControl x:ConnectionId='1'
    x:Class="SenaAurion.Controls.ResidueReviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SenaAurion.Controls"
    xmlns:viewmodels="using:SenaAurion.Controls">

    <UserControl.Resources>
        <CollectionViewSource x:ConnectionId='2' x:Name="GroupedView" IsSourceGrouped="True" />
    </UserControl.Resources>

    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:ConnectionId='3' Grid.Row="0"
                                                          
                   FontSize="12"
                   Foreground="#B3FFFFFF"
                   TextWrapping="WrapWholeWords"/>

        <ListView x:ConnectionId='4' Grid.Row="1"
                                                                      
                  Background="Transparent"
                  BorderThickness="0"
                  SelectionMode="None"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#E6FFFFFF"
                                       Margin="0,10,0,6"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>

            <ListView.ItemTemplate>
                <DataTemplate                                             >
                    <Grid x:ConnectionId='11' ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:ConnectionId='12'                                              VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:ConnectionId='13'                                   FontSize="11" Foreground="#D9FFFFFF" TextWrapping="WrapWholeWords"/>
                            <TextBlock x:ConnectionId='14'                                       FontSize="10" Foreground="#73FFFFFF"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:ConnectionId='7' Content="Seleccionar todo"                        />
                <Button x:ConnectionId='8' Content="Deseleccionar todo"                          />
            </StackPanel>

            <TextBlock x:ConnectionId='5' Grid.Column="1"                                                   FontSize="11" Foreground="#8CFFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <Button x:ConnectionId='6' Grid.Column="2" Content="Eliminar seleccionados"                             />
        </Grid>
    </Grid>
</UserControl>


