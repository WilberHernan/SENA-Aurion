<UserControl
    x:Class="SenaAurion.Controls.TrafficLightBulb"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <x:Double x:Key="Size">18</x:Double>

        <!-- Base palettes (tuned for dark glass UI) -->
        <Color x:Key="RedBase">#FFEB3B3B</Color>
        <Color x:Key="RedDark">#FF5A0F0F</Color>
        <Color x:Key="AmberBase">#FFFFB020</Color>
        <Color x:Key="AmberDark">#FF6A3B00</Color>
        <Color x:Key="GreenBase">#FF25D366</Color>
        <Color x:Key="GreenDark">#FF0B4A20</Color>
    </UserControl.Resources>

    <Grid Width="{StaticResource Size}" Height="{StaticResource Size}">
        <!-- Glow (only when ON) -->
        <Ellipse x:Name="Glow"
                 Opacity="0"
                 Width="{StaticResource Size}"
                 Height="{StaticResource Size}">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.85" RadiusY="0.85">
                    <GradientStop x:Name="GlowStop1" Color="#00FFFFFF" Offset="0" />
                    <GradientStop x:Name="GlowStop2" Color="#00FFFFFF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Glass dome -->
        <Ellipse x:Name="Dome"
                 Width="{StaticResource Size}"
                 Height="{StaticResource Size}"
                 StrokeThickness="1">
            <Ellipse.Stroke>
                <SolidColorBrush x:Name="BulbBorderBrush" Color="#33000000" />
            </Ellipse.Stroke>
            <Ellipse.Fill>
                <!-- Radial: bright top-left, darker bottom-right -->
                <RadialGradientBrush x:Name="DomeBrush"
                                     Center="0.32,0.30"
                                     GradientOrigin="0.22,0.18"
                                     RadiusX="0.95"
                                     RadiusY="0.95">
                    <GradientStop x:Name="DomeStop1" Color="#66FFFFFF" Offset="0" />
                    <GradientStop x:Name="DomeStop2" Color="#44FFFFFF" Offset="0.22" />
                    <GradientStop x:Name="DomeStop3" Color="#22111111" Offset="0.60" />
                    <GradientStop x:Name="DomeStop4" Color="#FF0D0D0D" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Inner shadow / depth -->
        <Ellipse Width="{StaticResource Size}" Height="{StaticResource Size}" Opacity="0.55">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.62,0.66" GradientOrigin="0.62,0.66" RadiusX="0.85" RadiusY="0.85">
                    <GradientStop Color="#00000000" Offset="0.55" />
                    <GradientStop Color="#66000000" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Specular highlight (only when ON) -->
        <Ellipse x:Name="Specular"
                 Width="7"
                 Height="5"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="4,4,0,0"
                 Opacity="0">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.3,0.3" GradientOrigin="0.2,0.2" RadiusX="1" RadiusY="1">
                    <GradientStop Color="#F2FFFFFF" Offset="0" />
                    <GradientStop Color="#00FFFFFF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="PowerStates">
                <VisualState x:Name="Off">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" />
                        <DoubleAnimation Storyboard.TargetName="Specular" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" />
                        <DoubleAnimation Storyboard.TargetName="Dome" Storyboard.TargetProperty="Opacity" To="0.38" Duration="0:0:0.12" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="On">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.65" Duration="0:0:0.12" />
                        <DoubleAnimation Storyboard.TargetName="Specular" Storyboard.TargetProperty="Opacity" To="0.9" Duration="0:0:0.12" />
                        <DoubleAnimation Storyboard.TargetName="Dome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>

