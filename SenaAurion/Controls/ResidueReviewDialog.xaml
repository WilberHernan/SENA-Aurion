<UserControl
    x:Class="SenaAurion.Controls.ResidueReviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SenaAurion.Controls"
    xmlns:viewmodels="using:SenaAurion.Controls">

    <UserControl.Resources>
        <CollectionViewSource x:Name="GroupedView" IsSourceGrouped="True" />
    </UserControl.Resources>

    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Bind HeaderText, Mode=OneWay}"
                   FontSize="12"
                   Foreground="#B3FFFFFF"
                   TextWrapping="WrapWholeWords"/>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind GroupedView.View, Mode=OneWay}"
                  Background="Transparent"
                  BorderThickness="0"
                  SelectionMode="None"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#E6FFFFFF"
                                       Margin="0,10,0,6"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:ResidueItemViewModel">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind Path, Mode=OneWay}" FontSize="11" Foreground="#D9FFFFFF" TextWrapping="WrapWholeWords"/>
                            <TextBlock Text="{x:Bind TypeText, Mode=OneWay}" FontSize="10" Foreground="#73FFFFFF"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Seleccionar todo" Click="SelectAll_Click"/>
                <Button Content="Deseleccionar todo" Click="DeselectAll_Click"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="{x:Bind SelectionSummaryText, Mode=OneWay}" FontSize="11" Foreground="#8CFFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <Button Grid.Column="2" Content="Eliminar seleccionados" Click="DeleteSelected_Click"/>
        </Grid>
    </Grid>
</UserControl>

