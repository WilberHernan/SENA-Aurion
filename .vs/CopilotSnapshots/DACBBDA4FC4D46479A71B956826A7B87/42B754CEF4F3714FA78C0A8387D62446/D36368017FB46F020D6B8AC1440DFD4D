using Microsoft.UI.Xaml;
using Microsoft.UI.Xaml.Controls;
using Microsoft.UI.Windowing;
using Windows.Graphics;
using System;

namespace VisionaryOptimizer
{
    public sealed partial class SplashWindow : Window
    {
        public SplashWindow()
        {
            this.InitializeComponent();

            // Set window size
            var hwnd = WinRT.Interop.WindowNative.GetWindowHandle(this);
            var windowId = Microsoft.UI.Win32Interop.GetWindowIdFromWindow(hwnd);
            var appWindow = AppWindow.GetFromWindowId(windowId);
            appWindow.Resize(new SizeInt32 { Width = 900, Height = 580 });

            // Center window (approximation without complex multi-monitor math)
            if (DisplayArea.GetFromWindowId(windowId, DisplayAreaFallback.Primary) is DisplayArea displayArea)
            {
                var workArea = displayArea.WorkArea;
                var x = workArea.X + (workArea.Width - 900) / 2;
                var y = workArea.Y + (workArea.Height - 580) / 2;
                appWindow.Move(new PointInt32 { X = x, Y = y });
            }

            // Custom TitleBar
            ExtendsContentIntoTitleBar = true;
            SetTitleBar(AppTitleBar);

            // Start Animation
            this.Activated += SplashWindow_Activated;
        }

        private void SplashWindow_Activated(object sender, WindowActivatedEventArgs args)
        {
            this.Activated -= SplashWindow_Activated;
            ScrollAnimation.Begin();
        }

        private void TopButton_Click(object sender, RoutedEventArgs e)
        {
            var mainWindow = new MainWindow();
            
            // Animación Splash (sale por la izquierda)
            var compositor = Microsoft.UI.Xaml.Hosting.ElementCompositionPreview.GetElementVisual(SplashRoot).Compositor;
            var splashVisual = Microsoft.UI.Xaml.Hosting.ElementCompositionPreview.GetElementVisual(SplashRoot);
            
            var slideOutAnimation = compositor.CreateVector3KeyFrameAnimation();
            slideOutAnimation.InsertKeyFrame(1.0f, new System.Numerics.Vector3(-(float)SplashRoot.ActualWidth, 0, 0), compositor.CreateCubicBezierEasingFunction(new System.Numerics.Vector2(0.2f, 0.0f), new System.Numerics.Vector2(0.0f, 1.0f)));
            slideOutAnimation.Duration = TimeSpan.FromMilliseconds(350);
            
            var fadeOutAnimation = compositor.CreateScalarKeyFrameAnimation();
            fadeOutAnimation.InsertKeyFrame(1.0f, 0.0f, compositor.CreateCubicBezierEasingFunction(new System.Numerics.Vector2(0.2f, 0.0f), new System.Numerics.Vector2(0.0f, 1.0f)));
            fadeOutAnimation.Duration = TimeSpan.FromMilliseconds(350);

            var batch = compositor.CreateScopedBatch(Microsoft.UI.Composition.CompositionBatchTypes.Animation);
            splashVisual.StartAnimation("Offset", slideOutAnimation);
            splashVisual.StartAnimation("Opacity", fadeOutAnimation);

            batch.Completed += (s, ev) =>
            {
                this.Close();
            };
            batch.End();

            mainWindow.Activate();
        }

        private async void SpecsButton_Click(object sender, RoutedEventArgs e)
        {
            SpecsModal.Visibility = Visibility.Visible;

            if (SpecsContainer.Children.Count == 0)
            {
                SpecsLoadingText.Visibility = Visibility.Visible;
                var info = await VisionaryOptimizer.Services.SystemInfoService.GetSystemInfoAsync();
                SpecsLoadingText.Visibility = Visibility.Collapsed;

                SpecsContainer.Children.Clear();

                AddSpecCard("SISTEMA OPERATIVO", $"{info.OsName} (Build {info.OsVersion})", $"{info.OsName} (Build {info.OsVersion})");
                AddSpecCard("NOMBRE DEL EQUIPO", info.MachineName, info.MachineName);
                AddSpecCard("DOMINIO / GRUPO", info.Domain, info.Domain);
                AddSpecCard("NÚMERO DE SERIE", info.SerialNumber, info.SerialNumber);
                AddSpecCard("PROCESADOR (CPU)", $"{info.CpuModel} | {info.CpuCoresText}", info.CpuModel);
                AddSpecCard("MEMORIA (RAM)", info.RamTotalText, info.RamTotalText);
                AddSpecCard("GRÁFICOS (GPU)", info.GpuModel, info.GpuModel);

                foreach (var disk in info.Disks)
                {
                    AddSpecCard("ALMACENAMIENTO", disk.DisplayText, disk.CopyText);
                }

                foreach (var net in info.MacAddresses)
                {
                    AddSpecCard("RED (MAC)", net.DisplayText, net.CopyText);
                }
            }
        }

        private void AddSpecCard(string label, string value, string copyText)
        {
            var border = new Border
            {
                CornerRadius = new CornerRadius(14),
                Background = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(25, 255, 255, 255)), // #19FFFFFF (Efecto frosted glass ligero)
                BorderBrush = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(38, 255, 255, 255)), // #26FFFFFF
                BorderThickness = new Thickness(1),
                Padding = new Thickness(20, 16, 20, 16)
            };

            var grid = new Grid();
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) });
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = GridLength.Auto });

            var stack = new StackPanel { Orientation = Orientation.Vertical, Spacing = 6, VerticalAlignment = VerticalAlignment.Center };
            Grid.SetColumn(stack, 0);

            var labelBlock = new TextBlock
            {
                Text = label,
                Foreground = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(217, 255, 255, 255)), // #D9FFFFFF
                FontSize = 12,
                FontFamily = new Microsoft.UI.Xaml.Media.FontFamily("Segoe UI Variable"),
                FontWeight = Microsoft.UI.Text.FontWeights.SemiBold
            };

            var valueBlock = new TextBlock
            {
                Text = value,
                Foreground = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(178, 255, 255, 255)), // #B2FFFFFF
                FontSize = 13,
                FontFamily = new Microsoft.UI.Xaml.Media.FontFamily("Cascadia Code"),
                TextWrapping = TextWrapping.Wrap,
                Margin = new Thickness(0, 0, 10, 0)
            };

            stack.Children.Add(labelBlock);
            stack.Children.Add(valueBlock);

            var copyButton = new Button
            {
                Background = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(25, 255, 255, 255)), // #19FFFFFF
                BorderThickness = new Thickness(1),
                BorderBrush = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(25, 255, 255, 255)),
                CornerRadius = new CornerRadius(8),
                Padding = new Thickness(12, 8, 12, 8),
                VerticalAlignment = VerticalAlignment.Center
            };
            Grid.SetColumn(copyButton, 1);

            var btnStack = new StackPanel { Orientation = Orientation.Horizontal, Spacing = 8 };
            var btnIcon = new FontIcon { Glyph = "\uE8C8", FontSize = 13, Foreground = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(217, 255, 255, 255)) };
            var btnText = new TextBlock { Text = "Copiar", FontSize = 12, Foreground = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(217, 255, 255, 255)) };
            btnStack.Children.Add(btnIcon);
            btnStack.Children.Add(btnText);
            copyButton.Content = btnStack;

            copyButton.Click += (s, e) =>
            {
                var package = new Windows.ApplicationModel.DataTransfer.DataPackage();
                package.SetText(copyText);
                Windows.ApplicationModel.DataTransfer.Clipboard.SetContent(package);

                btnIcon.Glyph = "\uE8FB"; // Checkmark XAML Icon
                btnText.Text = "Copiado";
                copyButton.Background = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(51, 29, 184, 112)); // Tono verde exito

                var timer = new DispatcherTimer { Interval = TimeSpan.FromSeconds(2) };
                timer.Tick += (ts, te) =>
                {
                    btnIcon.Glyph = "\uE8C8";
                    btnText.Text = "Copiar";
                    copyButton.Background = new Microsoft.UI.Xaml.Media.SolidColorBrush(Windows.UI.Color.FromArgb(25, 255, 255, 255));
                    timer.Stop();
                };
                timer.Start();
            };

            grid.Children.Add(stack);
            grid.Children.Add(copyButton);
            border.Child = grid;

            SpecsContainer.Children.Add(border);
        }

        private void CloseSpecsModal_Click(object sender, RoutedEventArgs e)
        {
            SpecsModal.Visibility = Visibility.Collapsed;
        }

        private void SpecsModal_PointerPressed(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
        {
            SpecsModal.Visibility = Visibility.Collapsed;
        }

        private void SpecsModalContent_PointerPressed(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
        {
            e.Handled = true; // Prevenir que el clic dentro del modal lo cierre
        }
    }
}