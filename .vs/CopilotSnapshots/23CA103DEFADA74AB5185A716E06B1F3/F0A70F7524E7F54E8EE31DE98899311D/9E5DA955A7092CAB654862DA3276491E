    private int GetMaxColumnsForResponsiveWidth()
    {
        double w = this.Bounds.Width;
        if (w > 2500) return 6;
        if (w > 1800) return 5;
        if (w > 1300) return 4;
        if (w > 900) return 3;
        if (w > 600) return 2;
        return 1;
    }

