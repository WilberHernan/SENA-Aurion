    private void PrepareDashboardInitialState()
    {
        var dashboardVisual = Microsoft.UI.Xaml.Hosting.ElementCompositionPreview.GetElementVisual(DashboardRoot);
        dashboardVisual.Offset = new System.Numerics.Vector3((float)Math.Max(HostRoot.ActualWidth, 1), 0, 0);
        dashboardVisual.Opacity = 1.0f;
    }
    private void TopButton_Click(object sender, RoutedEventArgs e)
    {
        if (_shellState != ShellState.SplashVisible || _isTransitioning)
        {
            return;
        }

        _isTransitioning = true;
        _shellState = ShellState.Transitioning;
        DashboardRoot.Visibility = Visibility.Visible;
        SpecsModal.Visibility = Visibility.Collapsed;

        var splashVisual = Microsoft.UI.Xaml.Hosting.ElementCompositionPreview.GetElementVisual(UIContainer);
        var dashboardVisual = Microsoft.UI.Xaml.Hosting.ElementCompositionPreview.GetElementVisual(DashboardRoot);
        var compositor = splashVisual.Compositor;
        float width = (float)Math.Max(HostRoot.ActualWidth, 1);

        dashboardVisual.Offset = new System.Numerics.Vector3(width, 0, 0);

        var easing = compositor.CreateCubicBezierEasingFunction(
            new System.Numerics.Vector2(0.2f, 0.9f),
            new System.Numerics.Vector2(0.4f, 1.1f));

        var splashSlideOut = compositor.CreateVector3KeyFrameAnimation();
        splashSlideOut.InsertKeyFrame(1.0f, new System.Numerics.Vector3(-width, 0, 0), easing);
        splashSlideOut.Duration = TimeSpan.FromMilliseconds(460);

        var dashboardSlideIn = compositor.CreateVector3KeyFrameAnimation();
        dashboardSlideIn.InsertKeyFrame(1.0f, new System.Numerics.Vector3(0, 0, 0), easing);
        dashboardSlideIn.Duration = TimeSpan.FromMilliseconds(460);

        var batch = compositor.CreateScopedBatch(CompositionBatchTypes.Animation);
        splashVisual.StartAnimation("Offset", splashSlideOut);
        dashboardVisual.StartAnimation("Offset", dashboardSlideIn);

        batch.Completed += (s, ev) =>
        {
            SplashRoot.Visibility = Visibility.Collapsed;
            _isTransitioning = false;
            _shellState = ShellState.DashboardVisible;
            ScrollAnimation.Stop();
            try
            {
                SetTitleBar(AppCustomTitleBar);
            }
            catch
            {
            }
        };

        batch.End();
    }

