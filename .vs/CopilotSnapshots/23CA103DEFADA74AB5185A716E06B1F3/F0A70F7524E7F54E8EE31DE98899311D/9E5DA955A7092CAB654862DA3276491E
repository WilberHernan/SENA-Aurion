    public MainShellWindow()
    {
        var log = new FileOptimizationLogger();
        var registry = new RegistryService(log);
        var services = new WindowsServiceOptimizer(log);
        var engine = new OptimizationEngine(log, registry, services);
        var provider = new JsonOptimizationDataProvider();

        ViewModel = new MainViewModel(provider, engine);

        try 
        {
            this.InitializeComponent();
        }
        catch (System.Exception ex)
        {
            System.Diagnostics.Debug.WriteLine(ex.ToString());
            throw;
        }

        try 
        {
            var hwnd = WinRT.Interop.WindowNative.GetWindowHandle(this);
            var windowId = Microsoft.UI.Win32Interop.GetWindowIdFromWindow(hwnd);
            var appWindow = AppWindow.GetFromWindowId(windowId);
            appWindow.Resize(new SizeInt32 { Width = 900, Height = 580 });

            if (DisplayArea.GetFromWindowId(windowId, DisplayAreaFallback.Primary) is DisplayArea displayArea)
            {
                var workArea = displayArea.WorkArea;
                var x = workArea.X + (workArea.Width - 900) / 2;
                var y = workArea.Y + (workArea.Height - 580) / 2;
                appWindow.Move(new PointInt32 { X = x, Y = y });
            }

            ExtendsContentIntoTitleBar = true;
            SetTitleBar(AppTitleBar);
        } catch { }

        ViewModel.SelectedTag = "home";

        this.Activated += MainWindow_Activated;
        this.SizeChanged += MainWindow_SizeChanged;
    }

    private void MainWindow_Activated(object sender, WindowActivatedEventArgs args)
    {
        this.Activated -= MainWindow_Activated;
        PrepareDashboardInitialState();
        ScrollAnimation.Begin();
    }

    private void MainWindow_SizeChanged(object sender, WindowSizeChangedEventArgs args)
    {
        if (!_isTransitioning && SplashRoot.Visibility == Visibility.Visible)
