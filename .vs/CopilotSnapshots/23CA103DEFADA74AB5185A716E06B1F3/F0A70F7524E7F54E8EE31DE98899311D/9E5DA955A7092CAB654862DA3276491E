    private void AttachTabHoverEvents(Button tb)
    {
        tb.PointerEntered += (s, e) =>
        {
            if (tb.Opacity < 1.0)
            {
                tb.Opacity = 0.8;
            }
        };

        tb.PointerExited += (s, e) =>
        {
            if (tb.Foreground is Microsoft.UI.Xaml.Media.SolidColorBrush b && b.Color.A < 160) // Not active (153 represents 60% approx)
            {
                tb.Opacity = 1.0;
            }
        };
    }

