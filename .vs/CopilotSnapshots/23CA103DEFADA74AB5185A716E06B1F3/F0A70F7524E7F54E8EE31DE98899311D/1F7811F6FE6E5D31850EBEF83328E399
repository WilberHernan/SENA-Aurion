<Window
    x:Class="SenaAurion.Shell.MainShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SenaAurion"
    xmlns:viewmodels="using:SenaAurion.ViewModels"
    xmlns:models="using:SenaAurion.Models"
    xmlns:services="using:SenaAurion.Services"
    Title="SENA AURION">

    <Grid x:Name="HostRoot">
        <Image Source="ms-appx:///Assets/Images/bg_splash.jpg" Stretch="UniformToFill" HorizontalAlignment="Right" />
        <Grid HorizontalAlignment="Left" Width="700" IsHitTestVisible="False">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF050C07" Offset="0.0" />
                    <GradientStop Color="#CC050C07" Offset="0.6" />
                    <GradientStop Color="#00050C07" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <Grid x:Name="DashboardRoot" MinWidth="600" MinHeight="500" Padding="8" ColumnSpacing="8" Background="Transparent" Visibility="Collapsed">
            <Grid.Resources>
            <AcrylicBrush x:Key="GlassSurfaceBrush" TintColor="#111111" TintOpacity="0.28" FallbackColor="#AA141414"/>
            <SolidColorBrush x:Key="NeoRaisedBrush" Color="#232323"/>
            <SolidColorBrush x:Key="NeoShadowDarkBrush" Color="#AA000000"/>
            <SolidColorBrush x:Key="NeoShadowLightBrush" Color="#22FFFFFF"/>

            <Style x:Key="NeoActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource NeoRaisedBrush}" />
                <Setter Property="BorderBrush" Value="#22FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="8" />
            </Style>
            <!-- Estilos MonocromÃ¡ticos Premium Dark -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="HomeCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Style x:Key="BodyMutedStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#66FFFFFF" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style x:Key="PrimaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="#2A2A2A" />
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            <Style x:Key="SecondaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="BorderBrush" Value="#1AFFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            
            <!-- Para no crear nuevos estilos complejos y mantener funcionalidad,
                 el texto accent de SENA lo ponemos monocromÃ¡tico aquÃ­. -->
            <SolidColorBrush x:Key="SenaTextAccentBrush" Color="#FFFFFF" />
            </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="56" /> <!-- Sidebar NavegaciÃ³n -->
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- BARRA SUPERIOR (TOPBAR) -->
            <Grid x:Name="AppCustomTitleBar" Grid.Row="0" Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" Height="46">
                <Grid Padding="18,0" Background="Transparent">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="{x:Bind ViewModel.CurrentModuleTitle, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" Foreground="#F2FFFFFF" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentModuleDescription, Mode=OneWay}" FontSize="11" Foreground="#8CFFFFFF" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- AREA DE CONTENIDO -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Border Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid x:Name="MainContainerContent">
                        <Button Width="36" Height="36" Style="{StaticResource NeoActionButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" Canvas.ZIndex="10" Click="BackToSplash_Click" ToolTipService.ToolTip="Volver al Splash">
                             <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#E6FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <TextBlock Text="{x:Bind ViewModel.CurrentModuleTitle, Mode=OneWay}" FontSize="84" FontWeight="ExtraBold" Foreground="#10FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <Grid Margin="76,34,76,30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
                                <TextBlock Text="{x:Bind ViewModel.CurrentModuleTitle, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" Foreground="#F2FFFFFF"/>
                                <TextBlock Text="{x:Bind ViewModel.CurrentModuleDescription, Mode=OneWay}" FontSize="12" Foreground="#A6FFFFFF" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <ListBox ItemsSource="{x:Bind ViewModel.CurrentModuleItems, Mode=OneWay}"
                                         SelectedItem="{x:Bind ViewModel.SelectedModuleItem, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollMode="Enabled">
                                    <ListBox.ItemContainerTransitions>
                                        <TransitionCollection>
                                            <ContentThemeTransition />
                                        </TransitionCollection>
                                    </ListBox.ItemContainerTransitions>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:TweakItemViewModel">
                                            <Grid Margin="0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock Text="{x:Bind DisplayName}" FontSize="14" Foreground="#F2FFFFFF" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="11" Foreground="#8CFFFFFF" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Rectangle VerticalAlignment="Top" Height="34" IsHitTestVisible="False">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#CC101010" Offset="0"/>
                                            <GradientStop Color="#00101010" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle VerticalAlignment="Bottom" Height="34" IsHitTestVisible="False">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00101010" Offset="0"/>
                                            <GradientStop Color="#CC101010" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,10,0,0">
                                <TextBlock Text="{x:Bind ViewModel.SelectedModuleDisplayName, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" Foreground="#E6FFFFFF"/>
                                <TextBlock Text="{x:Bind ViewModel.SelectedModuleDetail, Mode=OneWay}" TextWrapping="Wrap" FontSize="12" Foreground="#B3FFFFFF" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- COLUMNA DERECHA SECUNDARIA -->
        <Grid Grid.Column="1" RowSpacing="8" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- CARD SUPERIOR -->
            <Border Grid.Row="0" Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="NETWORK STATS" FontSize="13" FontWeight="Bold" Foreground="#D9FFFFFF" />
                    <TextBlock Text="SENA AURION optimiza rendimiento con reglas seguras y reversibles. Los cambios buscan estabilidad y fluidez sin comprometer la integridad del dispositivo." FontSize="10" Foreground="#9AFFFFFF" LineHeight="15" Margin="0,6,0,10" TextWrapping="Wrap" />
                    
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" Height="40" VerticalAlignment="Bottom" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <!-- Barras minificadas de ejemplo -->
                        <Border Width="8" Height="10" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="25" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="15" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="35" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="20" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="12" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="28" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,16,0,0">
                        <Ellipse Width="6" Height="6" Fill="#CCFFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- CARD INFERIOR -->
            <Border Grid.Row="1" Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" Padding="16">
                <StackPanel>
                    <Ellipse Width="64" Height="64" Margin="0,10" Stroke="#1AFFFFFF" StrokeThickness="1" HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3A3A3A" Offset="0"/>
                                <GradientStop Color="#111111" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="OPTIMIZER MOTOR" FontSize="13" FontWeight="Bold" Foreground="#D9FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Panel de ejecución del módulo activo." FontSize="10" Foreground="#8CFFFFFF" LineHeight="1.5" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,12"/>
                    <Button Content="Aplicar" Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="{x:Bind ViewModel.CurrentModuleActionName, Mode=OneWay}" Style="{StaticResource NeoActionButtonStyle}" Margin="0,0,0,8"/>
                    <Button Content="Revertir" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="{x:Bind ViewModel.CurrentModuleActionName, Mode=OneWay}" Style="{StaticResource NeoActionButtonStyle}" Margin="0,0,0,8"/>
                    <Button Content="Restaurar fábrica" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="{x:Bind ViewModel.CurrentModuleActionName, Mode=OneWay}" Style="{StaticResource NeoActionButtonStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SIDEBAR DE NAVEGACIÃ“N -->
        <Border Grid.Column="2" Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14">
            <Grid Padding="0,16">
                <!-- Ãconos de NavegaciÃ³n Verticalmente Centrados -->
                <StackPanel VerticalAlignment="Center" Spacing="16" HorizontalAlignment="Center">
                    <!-- Home -->
                    <Button Click="TabButton_Click" CommandParameter="home" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Inicio">
                        <Grid>
                            <Ellipse Width="36" Height="36" Fill="#2A2A2A" />
                            <FontIcon Glyph="&#xE80F;" FontSize="16" Foreground="#B3FFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Input -->
                    <Button Click="TabButton_Click" CommandParameter="input" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Input">
                        <Grid>
                            <FontIcon Glyph="&#xE144;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Network -->
                    <Button Click="TabButton_Click" CommandParameter="network" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Network">
                        <Grid>
                            <FontIcon Glyph="&#xE701;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                    
                    <!-- TCP -->
                    <Button Click="TabButton_Click" CommandParameter="network" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="TCP">
                        <Grid>
                            <FontIcon Glyph="&#xE968;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Servicios -->
                    <Button Click="TabButton_Click" CommandParameter="services" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Servicios">
                        <Grid>
                            <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Cleaner -->
                    <Button Click="TabButton_Click" CommandParameter="cleaner" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Limpieza">
                        <Grid>
                            <FontIcon Glyph="&#xE7FC;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        </Grid>

        <Grid x:Name="SplashRoot">
            <Grid.Resources>
                <AcrylicBrush x:Key="AcrylicGlassBrush" TintColor="#1A1A1A" TintOpacity="0.2" FallbackColor="#331A1A1A" />
                <Storyboard x:Name="ScrollAnimation" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="ScrollTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="14" Duration="0:0:0.9" AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>
            <Grid x:Name="UIContainer" RenderTransformOrigin="0.5,0.5">
                <Grid>
                    <Rectangle x:Name="AppTitleBar" Height="32" VerticalAlignment="Top" Fill="Transparent"/>
                    <Grid VerticalAlignment="Top" Padding="32,24,32,0" Margin="0,10,0,0">
                        <Path Data="M 18,0 L 36,9 L 36,27 L 18,36 L 0,27 L 0,9 Z M 18,7 A 11,11 0 1 0 18,29 A 11,11 0 1 0 18,7 Z"
                              Stroke="#1DB870" StrokeThickness="2" Fill="Transparent"
                              Width="36" Height="36" Stretch="Uniform"
                              HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Home" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="About" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="Services" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="Contact" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                        </StackPanel>
                        <Button Background="Transparent" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="20" Padding="8,7,8,7"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Click="TopButton_Click" Height="42">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Start Page" FontSize="12" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Grid Width="26" Height="26">
                                    <Path Data="M 4,10 L 16,10 M 10,4 L 16,10 L 10,16" Stroke="#FFFFFF" StrokeThickness="1.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="12" Height="12" />
                                </Grid>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,60,0,0">
                        <TextBlock Text="SENA&#x0a;AURION" FontFamily="Segoe UI" FontWeight="ExtraBold" FontSize="72" Foreground="#FFFFFF"
                                   CharacterSpacing="-120" LineStackingStrategy="BlockLineHeight" LineHeight="72" />
                        <TextBlock Text="Where Innovation Knows No Bounds" FontFamily="Segoe UI" FontSize="14"
                                   Foreground="#FFFFFF" Opacity="0.45" Margin="0,10,0,0" CharacterSpacing="30" />
                    </StackPanel>
                    <Button Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28" Click="SpecsButton_Click">
                        <Grid Width="28" Height="44">
                            <Border BorderBrush="#33FFFFFF" BorderThickness="1.5" CornerRadius="14" Background="Transparent" />
                            <Rectangle x:Name="ScrollIndicator" Width="4" Height="10" Fill="#80FFFFFF" RadiusX="2" RadiusY="2" VerticalAlignment="Top" Margin="0,6,0,0">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="ScrollTransform" Y="0"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="32,0,0,32" Spacing="20">
                        <Image Source="ms-appx:///Assets/Images/facebook.png" Width="18" Height="18" Opacity="0.8" Stretch="Uniform" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid x:Name="SpecsModal" Visibility="Collapsed" Padding="24" PointerPressed="SpecsModal_PointerPressed">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent" />
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" HorizontalAlignment="Stretch" Margin="0,24,0,24" PointerPressed="SpecsModalContent_PointerPressed">
                    <TextBlock Text="ESPECIFICACIONES DEL EQUIPO" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Foreground="#D9FFFFFF" CharacterSpacing="50" VerticalAlignment="Center"/>
                    <Button FontFamily="Segoe UI" FontSize="14" Width="40" Height="40" Padding="0"
                            Background="#1AFFFFFF" BorderThickness="1" BorderBrush="#33FFFFFF" CornerRadius="20" Foreground="#D9FFFFFF"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Click="CloseSpecsModal_Click">
                        <TextBlock Text="âœ•" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
                <TextBlock Grid.Row="1" x:Name="SpecsLoadingText" Text="Analizando hardware, por favor espera..." Foreground="#D9FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                <Grid Grid.Row="1" x:Name="SpecsContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,0,0,24" Padding="0" PointerPressed="SpecsModalContent_PointerPressed" SizeChanged="SpecsContainer_SizeChanged"/>
            </Grid>
        </Grid>
    </Grid>
</Window>

