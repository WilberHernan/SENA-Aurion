<Window
    x:Class="VisionaryOptimizer.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#050C07">
        <Grid.Resources>
            <Storyboard x:Name="ScrollAnimation" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="ScrollTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="0" To="14" Duration="0:0:0.9" AutoReverse="True">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>
        <!-- CAPA 1 Fondo -->
        <Image Source="ms-appx:///Assets/Images/bg_splash.jpg" 
               Stretch="UniformToFill" 
               HorizontalAlignment="Right" />

        <!-- CAPA 2 Gradiente -->
        <!-- Utilizamos un Grid en lugar de un Rectangle con Width fijo para mayor flexibilidad,
             pero de igual forma cubrimos el lado izquierdo para el degradado -->
        <Grid HorizontalAlignment="Left" Width="700">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF050C07" Offset="0.0" />
                    <GradientStop Color="#CC050C07" Offset="0.6" />
                    <GradientStop Color="#00050C07" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- CAPA 3 Contenido Principal -->
        <Grid>
            <!-- TitleBar Transparent Area -->
            <Rectangle x:Name="AppTitleBar" Height="32" VerticalAlignment="Top" Fill="Transparent"/>

            <!-- [A] NAVBAR SUPERIOR -->
            <Grid VerticalAlignment="Top" Padding="32,24,32,0" Margin="0,10,0,0">
                <!-- IZQUIERDA: Logo del programa -->
                <Path Data="M 18,0 L 36,9 L 36,27 L 18,36 L 0,27 L 0,9 Z M 18,7 A 11,11 0 1 0 18,29 A 11,11 0 1 0 18,7 Z" 
                      Stroke="#1DB870" StrokeThickness="2" Fill="Transparent"
                      Width="36" Height="36" Stretch="Uniform" 
                      HorizontalAlignment="Left" VerticalAlignment="Center" />

                <!-- CENTRO: Links de navegación -->
                <StackPanel Orientation="Horizontal" Spacing="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Home" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                    <TextBlock Text="About" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                    <TextBlock Text="Services" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                    <TextBlock Text="Contact" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                </StackPanel>

                <!-- DERECHA: Botón "Start Page" -->
                <Button Background="Transparent" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="20" Padding="8,7,8,7" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" Click="TopButton_Click" Height="42">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Start Page" FontSize="12" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Grid Width="26" Height="26">
                            <Path Data="M 4,10 L 16,10 M 10,4 L 16,10 L 10,16" Stroke="#FFFFFF" StrokeThickness="1.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="12" Height="12" />
                        </Grid>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- [B] HERO TEXT -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,60,0,0">
                <TextBlock Text="SENA&#x0a;AURION" FontFamily="Segoe UI" FontWeight="ExtraBold" FontSize="72" Foreground="#FFFFFF" 
                           CharacterSpacing="-120" LineStackingStrategy="BlockLineHeight" LineHeight="72" />
                <TextBlock Text="Where Innovation Knows No Bounds" FontFamily="Segoe UI" FontSize="14" 
                           Foreground="#FFFFFF" Opacity="0.45" Margin="0,10,0,0" CharacterSpacing="30" />
            </StackPanel>

            <!-- [C] ÍCONO DE SCROLL -->
            <Button Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28" Click="TopButton_Click">
                <Grid Width="28" Height="44">
                    <!-- Borde exterior -->
                    <Border BorderBrush="#33FFFFFF" BorderThickness="1.5" CornerRadius="14" Background="Transparent" />
                    <!-- Elemento interno animado -->
                    <Rectangle x:Name="ScrollIndicator" Width="4" Height="10" Fill="#80FFFFFF" RadiusX="2" RadiusY="2" VerticalAlignment="Top" Margin="0,6,0,0">
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="ScrollTransform" Y="0"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Grid>
            </Button>

            <!-- [D] ÍCONOS DE REDES SOCIALES -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="32,0,0,32" Spacing="20">
                <!-- Facebook (F aproximada) -->
                <PathIcon Data="M 12,5 L 15,5 L 15,1 L 12,1 C 9,1 7,3 7,6 L 7,9 L 4,9 L 4,13 L 7,13 L 7,20 L 11,20 L 11,13 L 14,13 L 15,9 L 11,9 L 11,6 C 11,5 11,5 12,5 Z" Foreground="#66FFFFFF" Width="14" Height="14"/>
                <!-- Instagram (Cámara aproximada) -->
                <PathIcon Data="M 6,3 C 4,3 3,4 3,6 L 3,14 C 3,16 4,17 6,17 L 14,17 C 16,17 17,16 17,14 L 17,6 C 17,4 16,3 14,3 L 6,3 Z M 10,6 C 12.2,6 14,7.8 14,10 C 14,12.2 12.2,14 10,14 C 7.8,14 6,12.2 6,10 C 6,7.8 7.8,6 10,6 Z" Foreground="#66FFFFFF" Width="14" Height="14" />
                <!-- Twitter/X -->
                <Path Data="M 4,4 L 10,10 M 10,10 L 16,16 M 16,4 L 4,16" Stroke="#66FFFFFF" Width="14" Height="14" StrokeThickness="1.5" Stretch="Uniform" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>