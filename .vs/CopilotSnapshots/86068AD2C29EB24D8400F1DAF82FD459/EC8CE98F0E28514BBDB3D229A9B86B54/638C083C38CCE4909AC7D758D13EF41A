<Application
    x:Class="VisionaryOptimizer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#FFFFFF</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#FFFFFF</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="AppBackground" Color="#111111" />
            <SolidColorBrush x:Key="SurfacePrimary" Color="#1A1A1A" />
            <SolidColorBrush x:Key="SurfaceSecondary" Color="#222222" />
            <SolidColorBrush x:Key="SurfaceActive" Color="#2A2A2A" />
            <SolidColorBrush x:Key="TextPrimary" Color="#D9FFFFFF" />
            <SolidColorBrush x:Key="TextSecondary" Color="#73FFFFFF" />
            <SolidColorBrush x:Key="TextMuted" Color="#33FFFFFF" />
            <SolidColorBrush x:Key="BorderSubtle" Color="#12FFFFFF" />
            <SolidColorBrush x:Key="BorderNormal" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="ButtonLight" Color="#F0F0F0" />
            <SolidColorBrush x:Key="ButtonDark" Color="#111111" />

            <FontFamily x:Key="InterFont">Segoe UI Variable</FontFamily>
            <FontFamily x:Key="MontserratFont">Segoe UI Variable</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Code</FontFamily>

            <!-- Retrocompatibilidad sin romper el antiguo esquema -->
            <SolidColorBrush x:Key="SenaPrimaryBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SenaTextAccentBrush" Color="#D9FFFFFF" />
            <SolidColorBrush x:Key="SenaWarningBrush" Color="#D9FFFFFF" />
            <SolidColorBrush x:Key="SenaMainBackgroundBrush" Color="#111111" />
            
            <SolidColorBrush x:Key="GlassCardBackground" Color="#1A1A1A" />
            <SolidColorBrush x:Key="GlassCardHoverBackground" Color="#222222" />
            
            <Style x:Key="CustomCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground" Value="#D9FFFFFF"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
            </Style>

            <!-- Text Formatting -->
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
                <Setter Property="Foreground" Value="#8A9E94" />
                <Setter Property="CharacterSpacing" Value="80" />
            </Style>

            <!-- Page Title Formatting -->
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="ExtraBold" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
                <Setter Property="Foreground" Value="#F0F4F2" />
                <Setter Property="CharacterSpacing" Value="60" />
            </Style>

            <!-- Muted Text Subtext -->
            <Style x:Key="BodyMutedStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
                <Setter Property="Foreground" Value="#8A9E94" />
                <Setter Property="FontSize" Value="14" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
