<Window
    x:Class="VisionaryOptimizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer"
    xmlns:viewmodels="using:VisionaryOptimizer.ViewModels"
    xmlns:models="using:VisionaryOptimizer.Models"
    xmlns:services="using:VisionaryOptimizer.Services"
    Title="Visionary Optimizer">

    <Grid Background="#111111" x:Name="RootGrid" MinWidth="600" MinHeight="500" Padding="8" ColumnSpacing="8">
        <Grid.Resources>
            <!-- Estilos Monocromáticos Premium Dark -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="HomeCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style]
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Style x:Key="BodyMutedStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#66FFFFFF" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style x:Key="PrimaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="#2A2A2A" />
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            <Style x:Key="SecondaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="BorderBrush" Value="#1AFFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            
            <!-- Para no crear nuevos estilos complejos y mantener funcionalidad,
                 el texto accent de SENA lo ponemos monocromático aquí. -->
            <SolidColorBrush x:Key="SenaTextAccentBrush" Color="#FFFFFF" />
        </Grid.Resources>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ResponsiveStates">
                <!-- Pantalla Ancha -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200"/>
                    </VisualState.StateTriggers>
                </VisualState>
                <!-- Pantalla Mediana -->
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="TabHomeText.Visibility" Value="Collapsed" />
                        <Setter Target="TabInputText.Visibility" Value="Collapsed" />
                        <Setter Target="TabNetworkText.Visibility" Value="Collapsed" />
                        <Setter Target="TabServicesText.Visibility" Value="Collapsed" />
                        <Setter Target="TabCleanerText.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <!-- Pantalla Pequeña -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="TabHomeText.Visibility" Value="Collapsed" />
                        <Setter Target="TabInputText.Visibility" Value="Collapsed" />
                        <Setter Target="TabNetworkText.Visibility" Value="Collapsed" />
                        <Setter Target="TabServicesText.Visibility" Value="Collapsed" />
                        <Setter Target="TabCleanerText.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="56" /> <!-- Sidebar Navegación -->
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- BARRA SUPERIOR (TOPBAR) -->
            <Grid x:Name="AppCustomTitleBar" Grid.Row="0" Background="#1A1A1A" CornerRadius="14" Height="46">
                <!-- Pills de navegación y Control Central -->
                <Grid Padding="14,0" Background="Transparent">
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="8">
                        <Button x:Name="TabHome" CommandParameter="home" Click="TabButton_Click" Background="Transparent" Foreground="#E6FFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TabHomeText" Text="Inicio" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="TabInput" CommandParameter="input" Click="TabButton_Click" Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TabInputText" Text="Input" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="TabNetwork" CommandParameter="network" Click="TabButton_Click" Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TabNetworkText" Text="Network" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="TabServices" CommandParameter="services" Click="TabButton_Click" Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TabServicesText" Text="Services" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="TabCleaner" CommandParameter="cleaner" Click="TabButton_Click" Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="14,5" FontFamily="{StaticResource InterFont}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TabCleanerText" Text="Cleaner" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Titulo Central -->
                    <TextBlock Text="SENA AURION" FontSize="13" FontFamily="{StaticResource InterFont}" FontWeight="Bold" Foreground="#80FFFFFF" CharacterSpacing="60" HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- Ícono Derecha -->
                    <Border CornerRadius="14" Width="28" Height="28" BorderThickness="1" BorderBrush="#26FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE90C;" FontSize="12" Foreground="#80FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Grid>

            <!-- AREA DE CONTENIDO -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Border Background="#1A1A1A" CornerRadius="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid x:Name="MainContainerContent">
                        <!-- Flecha Salida -->
                        <Border Width="36" Height="36" CornerRadius="18" BorderBrush="#33FFFFFF" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" Canvas.ZIndex="10">
                             <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#99FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- INICIO / DASHBOARD -->
                        <Grid Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionHome), Mode=OneWay}">
                            <TextBlock Text="INICIO" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="DETALLES DEL EQUIPO" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Vista general del entorno y recursos físicos." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Celda 1 -->
                                        <Border Grid.Column="0" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.RamTotalText, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="RAM" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Celda 2 -->
                                        <Border Grid.Column="1" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.CpuCoresText, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="CPU" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Celda 3 -->
                                        <Border Grid.Column="2" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.Disks.Count, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="DISCOS" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Celda 4 -->
                                        <Border Grid.Column="3" Background="#222222" CornerRadius="10" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.MacAddresses.Count, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#CCFFFFFF" />
                                                <TextBlock Text="REDS" FontSize="8" Foreground="#33FFFFFF" CharacterSpacing="80" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN INPUT (RATÓN/TECLADO) -->
                        <Grid Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionInput), Mode=OneWay}">
                            <TextBlock Text="INPUT" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="INPUT RESPONSE" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Reducción extrema de latencia en periféricos." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.InputTweakItems, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="viewmodels:TweakItemViewModel">
                                                    <Grid Margin="0,0,0,12">
                                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Input" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="APLICAMOS SELECCIÓN" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,12,0,0">
                                        <Button Content="Revertir" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="Input" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                        <Button Content="Fábrica" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="Input" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN RED Y TCP -->
                        <Grid Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionNetwork), Mode=OneWay}">
                            <TextBlock Text="NETWORK" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="NETWORK &amp; TCP" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Optimiza el protocolo TCP/IP para priorizar el ping en aplicaciones." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.NetworkTweakItems, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="viewmodels:TweakItemViewModel">
                                                    <Grid Margin="0,0,0,12">
                                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Network" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="APLICAR RED" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,12,0,0">
                                        <Button Content="Revertir" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="Network" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                        <Button Content="Fábrica" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="Network" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN SERVICIOS DE WINDOWS -->
                        <Grid Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionServices), Mode=OneWay}">
                            <TextBlock Text="SERVICES" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="SERVICIOS DE SISTEMA" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Deshabilita servicios innecesarios que consumen recursos." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.ServiceTweakItems, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="viewmodels:ServiceTweakModel">
                                                    <Grid Margin="0,0,0,12">
                                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" IsEnabled="{x:Bind IsToggleEnabled, Mode=OneWay}" VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                            <TextBlock Text="⚠️ Protegido Wi-Fi" Visibility="{x:Bind IsWifiLockedVisibility, Mode=OneWay}" Foreground="#D4944A" FontSize="10" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Services" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="MUTR SERVICIOS" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,12,0,0">
                                        <Button Content="Revertir" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="Services" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                        <Button Content="Fábrica" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="Services" Background="Transparent" Foreground="#66FFFFFF" BorderThickness="0" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SECCIÓN LIMPIEZA DE WINDOWS -->
                        <Grid Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionCleaner), Mode=OneWay}">
                            <TextBlock Text="CLEANER" FontSize="72" FontWeight="ExtraBold" Foreground="#08FFFFFF" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <Border CornerRadius="16" Padding="20" Margin="20" Background="#66000000" BorderBrush="#0FFFFFFF" BorderThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="LIMPIEZA DE SISTEMA" FontSize="16" FontWeight="Bold" Foreground="#E6FFFFFF" LineHeight="1.2" />
                                    <TextBlock Text="Elimina archivos temporales y basura." FontSize="11" Foreground="#66FFFFFF" Margin="0,6,0,16" LineHeight="1.5" TextWrapping="Wrap" />
                                    
                                    <ScrollViewer MaxHeight="200" Margin="0,0,0,16" Padding="0,0,12,0">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.CleanerTweakItems, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="viewmodels:CleanerTweakModel">
                                                    <Grid Margin="0,0,0,12">
                                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Top"/>
                                                        <StackPanel Margin="30,0,0,0">
                                                            <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                                            <TextBlock Text="⚠️ ELIMINARÁ CARPETAS" Visibility="{x:Bind IsDangerVisibility, Mode=OneWay}" Foreground="#E05555" FontSize="10" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Cleaner" Background="#F0F0F0" CornerRadius="24" Padding="16,8,8,8" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="EJECUTAR LIMPIEZA" FontSize="12" FontWeight="SemiBold" Foreground="#111111" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,32,0"/>
                                            <Ellipse Width="26" Height="26" Fill="#111111" HorizontalAlignment="Right" />
                                            <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#FFFFFF" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- COLUMNA DERECHA SECUNDARIA -->
        <Grid Grid.Column="1" RowSpacing="8" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- CARD SUPERIOR -->
            <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="NETWORK STATS" FontSize="13" FontWeight="Bold" Foreground="#D9FFFFFF" />
                    <TextBlock Text="Actividad de red y latencia en ms." FontSize="10" Foreground="#4DFFFFFF" LineHeight="1.5" Margin="0,6,0,10" TextWrapping="Wrap" />
                    
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" Height="40" VerticalAlignment="Bottom" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <!-- Barras minificadas de ejemplo -->
                        <Border Width="8" Height="10" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="25" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="15" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="35" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="20" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="12" Background="#26FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                        <Border Width="8" Height="28" Background="#80FFFFFF" CornerRadius="4" VerticalAlignment="Bottom"/>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,16,0,0">
                        <Ellipse Width="6" Height="6" Fill="#CCFFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                        <Ellipse Width="6" Height="6" Fill="#33FFFFFF" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- CARD INFERIOR -->
            <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="14" Padding="16">
                <StackPanel>
                    <Ellipse Width="64" Height="64" Margin="0,10" Stroke="#1AFFFFFF" StrokeThickness="1" HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3A3A3A" Offset="0"/>
                                <GradientStop Color="#111111" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="OPTIMIZER" FontSize="13" FontWeight="Bold" Foreground="#D9FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Motor listo." FontSize="10" Foreground="#4DFFFFFF" LineHeight="1.5" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SIDEBAR DE NAVEGACIÓN -->
        <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="14">
            <Grid Padding="0,16">
                <!-- Íconos de Navegación Verticalmente Centrados -->
                <StackPanel VerticalAlignment="Center" Spacing="16" HorizontalAlignment="Center">
                    <!-- Home -->
                    <Button Click="TabButton_Click" CommandParameter="home" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Inicio">
                        <Grid>
                            <Ellipse Width="36" Height="36" Fill="#2A2A2A" />
                            <FontIcon Glyph="&#xE80F;" FontSize="16" Foreground="#B3FFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Input -->
                    <Button Click="TabButton_Click" CommandParameter="input" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Input">
                        <Grid>
                            <FontIcon Glyph="&#xE144;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Network -->
                    <Button Click="TabButton_Click" CommandParameter="network" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Network">
                        <Grid>
                            <FontIcon Glyph="&#xE701;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                    
                    <!-- TCP -->
                    <Button Click="TabButton_Click" CommandParameter="network" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="TCP">
                        <Grid>
                            <FontIcon Glyph="&#xE968;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Servicios -->
                    <Button Click="TabButton_Click" CommandParameter="services" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Servicios">
                        <Grid>
                            <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Cleaner -->
                    <Button Click="TabButton_Click" CommandParameter="cleaner" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="10" Width="36" Height="36" ToolTipService.ToolTip="Limpieza">
                        <Grid>
                            <FontIcon Glyph="&#xE7FC;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
