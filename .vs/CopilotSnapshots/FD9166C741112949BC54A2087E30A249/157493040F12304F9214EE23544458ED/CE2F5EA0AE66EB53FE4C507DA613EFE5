    private void Log(string message)
    {
        if (string.IsNullOrWhiteSpace(message)) return;
        InstallLogs += $"[{DateTime.Now:HH:mm:ss}] {message}\n";
    }

    private void SetBusy(bool isBusy, string message)
    {
        _setBusyStatus(isBusy, message);
    }

    private async Task<string> ExecuteWingetAsync(string arguments)
    {
        string downloadDir = System.IO.Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), "Downloads");
        string fullArgs = arguments;
        string script = $@"
$ErrorActionPreference = 'SilentlyContinue'
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8

$winget = (Get-Command winget.exe -ErrorAction SilentlyContinue).Source
if (-not $winget) {{
    $winget = Join-Path $env:LOCALAPPDATA 'Microsoft\WindowsApps\winget.exe'
}}
if (-not (Test-Path $winget)) {{
    $winget = Join-Path $env:ProgramFiles 'WindowsApps\Microsoft.DesktopAppInstaller_*_x64__8wekyb3d8bbwe\winget.exe'
}}
& $winget {fullArgs}
";
        string encodedCommand = Convert.ToBase64String(System.Text.Encoding.Unicode.GetBytes(script));

        var psi = new System.Diagnostics.ProcessStartInfo
        {
            FileName = "powershell.exe",
            Arguments = $"-NoProfile -ExecutionPolicy Bypass -EncodedCommand {encodedCommand}",
            UseShellExecute = false,
            CreateNoWindow = true,
            RedirectStandardOutput = true,
            RedirectStandardError = true,
            StandardOutputEncoding = System.Text.Encoding.UTF8,
            StandardErrorEncoding = System.Text.Encoding.UTF8,
            WorkingDirectory = downloadDir
        };

        var dispatcher = Microsoft.UI.Dispatching.DispatcherQueue.GetForCurrentThread();
        var outputBuilder = new System.Text.StringBuilder();

        try
        {
            using var process = System.Diagnostics.Process.Start(psi);
            if (process == null) return "error";

            Task ReadStreamAsync(System.IO.StreamReader reader)
            {
                return Task.Run(async () =>
                {
                    var buffer = new char[128];
                    int read;
                    var lineBuf = new System.Text.StringBuilder();

                    while ((read = await reader.ReadAsync(buffer, 0, buffer.Length)) > 0)
                    {
                        string chunk = new string(buffer, 0, read);
                        outputBuilder.Append(chunk);

                        foreach (char c in chunk)
                        {
                            if (c == '\r' || c == '\n')
                            {
                                if (lineBuf.Length > 0)
                                {
                                    string line = lineBuf.ToString().Trim();
                                    lineBuf.Clear();

                                    if (!string.IsNullOrEmpty(line))
                                    {
                                        string msg = line.Trim();
                                        dispatcher.TryEnqueue(() => 
                                        {
                                            if (msg.Contains(""██"") || (msg.Contains(""%"") && msg.Length > 20))
                                            {
                                                SetBusy(true, msg); 
                                            }
                                            else 
                                            {
                                                Log(msg);
                                                SetBusy(true, msg);
                                            }
                                        });
                                    }
                                }
                            }
                            else
                            {
                                lineBuf.Append(c);
                            }
                        }
                    }
                    if (lineBuf.Length > 0)
                    {
                        string lastLine = lineBuf.ToString().Trim();
                        dispatcher.TryEnqueue(() => { Log(lastLine); SetBusy(true, lastLine); });
                    }
                });
            }

            var t1 = ReadStreamAsync(process.StandardOutput);
            var t2 = ReadStreamAsync(process.StandardError);

            await process.WaitForExitAsync();
            await Task.WhenAll(t1, t2);

            return outputBuilder.ToString();
        }
        catch (Exception ex)
        {
            dispatcher.TryEnqueue(() => Log($""❌ Error Winget: {ex.Message}""));
            return ""error"";
        }
    }
