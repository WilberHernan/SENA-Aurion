    [RelayCommand]
    public async Task DetectInstalledAppsAsync()
    {
        SetBusy(true, "Detectando aplicaciones instaladas...");
        InstallLogs = "Detectando aplicaciones instaladas mediante Winget...\n";

        try
        {
            string output = await ExecuteWingetAsync("list");

            if (output != "error")
            {
                foreach (var app in AllAppItems)
                {
                    app.IsInstalled = output.Contains(app.WingetId, StringComparison.OrdinalIgnoreCase);
                }
                Log("Detección completada.");
                SetBusy(true, "Detección completada.");
            }
        }
        finally
        {
            SetBusy(false, "Sistema listo");
        }
    }

    [RelayCommand]
    public async Task InstallSelectedAppsAsync()
    {
        var selected = AllAppItems.Where(a => a.IsSelected).ToList();
        if(!selected.Any()) return;

        SetBusy(true, "Iniciando instalación de lote...");
        Log("Comenzando instalación de lote...");

        try
        {
            foreach(var app in selected)
            {
                SetBusy(true, $"Iniciando instalación de {app.Name}...");
                Log($"Iniciando instalación de {app.Name}...");

                string res = await ExecuteWingetAsync($"install --id {app.WingetId} --silent --accept-package-agreements --accept-source-agreements --force");

                if (res != "error" && !res.Contains("failed", StringComparison.OrdinalIgnoreCase))
                {
                    Log($"✅ Instalación completada exitosamente: {app.Name}");
                }
                else
                {
                    Log($"❌ Error en la instalación de {app.Name}");
                }
            }
        }
        finally
        {
            SetBusy(false, "Instalación de lote finalizada");
            await DetectInstalledAppsAsync(); // Refresh
        }
    }

    [RelayCommand]
