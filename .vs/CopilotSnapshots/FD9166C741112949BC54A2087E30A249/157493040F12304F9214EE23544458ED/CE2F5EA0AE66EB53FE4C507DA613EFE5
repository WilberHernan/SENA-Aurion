                SetBusy(true, $"Iniciando desinstalación de {app.Name}...");
                Log($"Iniciando desinstalación de {app.Name}...");

                string res = await ExecuteWingetAsync($"uninstall --id {app.WingetId} --silent --accept-source-agreements --force");

