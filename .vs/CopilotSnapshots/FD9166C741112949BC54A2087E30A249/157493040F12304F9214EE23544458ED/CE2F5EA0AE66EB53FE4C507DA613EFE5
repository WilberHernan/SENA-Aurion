    private void FilterApps()
    {
        FilteredAppItems.Clear();
        foreach (var app in AllAppItems)
        {
            if (InstallerSelectedCategory != "Todas" && app.Category != InstallerSelectedCategory)
                continue;

            if (!string.IsNullOrWhiteSpace(InstallerSearchText) && 
                !app.Name.Contains(InstallerSearchText, StringComparison.OrdinalIgnoreCase))
                continue;

            FilteredAppItems.Add(app);
        }
    }

