<Application
    x:Class="VisionaryOptimizer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Tokens de color coherentes con Mica Alt -->
            <SolidColorBrush x:Key="VisionaryCardBackground" Color="#40FFFFFF" />
            <SolidColorBrush x:Key="VisionaryBorderBrush" Color="#33FFFFFF" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
