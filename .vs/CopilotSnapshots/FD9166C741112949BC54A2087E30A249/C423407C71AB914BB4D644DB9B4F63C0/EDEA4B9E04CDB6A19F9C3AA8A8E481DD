    [RelayCommand]
    public async Task DetectInstalledAppsAsync()
    {
        SetBusy(true, "Detectando aplicaciones instaladas...");
        LogUI("Detectando aplicaciones instaladas mediante Winget...");

        try
        {
            // list NO necesita elevación → modo normal sin runas
            string output = await RunWingetReadAsync("list --accept-source-agreements");

            if (!string.IsNullOrEmpty(output) && output != "error")
            {
                foreach (var app in AllAppItems)
                    app.IsInstalled = output.Contains(app.WingetId, StringComparison.OrdinalIgnoreCase);

                LogUI("✅ Detección completada.");
            }
            else
            {
                LogUI("⚠️ No se pudo obtener la lista de aplicaciones. ¿Winget está instalado?");
            }
        }
        catch (Exception ex)
        {
            LogUI($"❌ Error detección: {ex.Message}");
        }
        finally
        {
            SetBusy(false, "Sistema listo");
        }
    }

    [RelayCommand]
    public async Task InstallSelectedAppsAsync()
    {
        var selected = AllAppItems.Where(a => a.IsSelected).ToList();
        if (!selected.Any()) return;

        SetBusy(true, "Iniciando instalación de lote...");
        LogUI("Comenzando instalación de lote...");

        try
        {
            // Construir script que instala todos en secuencia y escribe log a archivo
            string logFile = System.IO.Path.Combine(
                System.IO.Path.GetTempPath(), $"winget_install_{DateTime.Now:yyyyMMdd_HHmmss}.log");

            var lines = new System.Text.StringBuilder();
            lines.AppendLine("[Console]::OutputEncoding = [System.Text.Encoding]::UTF8");
            lines.AppendLine($"$log = '{logFile}'");
            lines.AppendLine("function WLog($m) { $ts = Get-Date -Format 'HH:mm:ss'; \"[$ts] $m\" | Tee-Object -FilePath $log -Append | Write-Host }");

            foreach (var app in selected)
            {
                lines.AppendLine($"WLog 'INICIO: {app.Name}'");
                lines.AppendLine($"winget install --id {app.WingetId} --silent --accept-package-agreements --accept-source-agreements --force");
                lines.AppendLine($"if ($LASTEXITCODE -eq 0) {{ WLog 'OK: {app.Name}' }} else {{ WLog \"ERROR: {app.Name} (exit $LASTEXITCODE)\" }}");
            }

            lines.AppendLine("WLog 'BATCH_DONE'");

            await RunElevatedScriptWithLogTailAsync(lines.ToString(), logFile, selected.Count);
        }
        finally
        {
            SetBusy(false, "Instalación finalizada");
            await DetectInstalledAppsAsync();
        }
    }

    [RelayCommand]
