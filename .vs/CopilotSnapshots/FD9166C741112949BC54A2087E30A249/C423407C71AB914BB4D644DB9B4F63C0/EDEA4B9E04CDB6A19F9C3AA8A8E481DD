            lines.AppendLine($"$log = '{logFile}'");
            lines.AppendLine("function WLog($m) { $ts = Get-Date -Format 'HH:mm:ss'; \"[$ts] $m\" | Tee-Object -FilePath $log -Append | Write-Host }");

            foreach (var app in selected)
            {
                lines.AppendLine($"WLog 'INICIO_DESINST: {app.Name}'");
                lines.AppendLine($"winget uninstall --id {app.WingetId} --silent --accept-source-agreements --force");
                lines.AppendLine($"if ($LASTEXITCODE -eq 0) {{ WLog 'OK_DESINST: {app.Name}' }} else {{ WLog \"ERROR_DESINST: {app.Name} (exit $LASTEXITCODE)\" }}");
            }

            lines.AppendLine("WLog 'BATCH_DONE'");

            await RunElevatedScriptWithLogTailAsync(lines.ToString(), logFile, selected.Count);
        }
        finally
        {
            SetBusy(false, "Desinstalación finalizada");
            await DetectInstalledAppsAsync();
        }
    }

