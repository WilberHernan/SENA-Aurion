    //  MOTOR PRINCIPAL — script elevado + tail de log
    // ─────────────────────────────────────────────

    /// <summary>
    /// Escribe el script a un .ps1 temporal, lo lanza con -Verb runas (UAC)
    /// y mientras corre va leyendo el archivo de log para mostrar progreso en UI.
    /// </summary>
    private async Task RunElevatedScriptWithLogTailAsync(string scriptContent, string logFile, int appCount)
    {
        // 1. Escribir script temporal
        string scriptPath = System.IO.Path.Combine(System.IO.Path.GetTempPath(),
            $"vo_winget_{Guid.NewGuid():N}.ps1");

        await System.IO.File.WriteAllTextAsync(scriptPath, scriptContent, System.Text.Encoding.UTF8);

        // 2. Lanzar PowerShell elevado (UAC) — NO redirigir stdout, eso bloquea runas
        var psi = new System.Diagnostics.ProcessStartInfo
        {
            FileName = "powershell.exe",
            Arguments = $"-NoProfile -ExecutionPolicy Bypass -File \"{scriptPath}\"",
            UseShellExecute = true,   // REQUERIDO para Verb runas
            Verb = "runas",           // Pide elevación UAC
            WindowStyle = System.Diagnostics.ProcessWindowStyle.Hidden,
            CreateNoWindow = false    // Con runas no funciona CreateNoWindow=true
        };

        System.Diagnostics.Process? process;
        try
        {
            process = System.Diagnostics.Process.Start(psi);
        }
        catch (System.ComponentModel.Win32Exception ex) when (ex.NativeErrorCode == 1223)
        {
            // Usuario canceló el UAC
            LogUI("⚠️ Operación cancelada: el usuario rechazó la elevación UAC.");
            return;
        }

        if (process == null)
        {
            LogUI("❌ No se pudo iniciar el proceso de instalación.");
            return;
        }

        // 3. Tail del log mientras el proceso corre
        long lastPos = 0;
        int doneCount = 0;

        while (!process.HasExited)
        {
            await Task.Delay(300);
            (lastPos, doneCount) = ReadNewLogLines(logFile, lastPos, doneCount, appCount);
        }

        // Leer líneas finales tras el exit
        await Task.Delay(500);
        ReadNewLogLines(logFile, lastPos, doneCount, appCount);

        // 4. Limpiar script temporal
        try { System.IO.File.Delete(scriptPath); } catch { /* no crítico */ }
    }

    /// <summary>
    /// Lee líneas nuevas del archivo de log y las muestra en UI.
    /// Devuelve la nueva posición y contador de apps completadas.
    /// </summary>
    private (long newPos, int newDone) ReadNewLogLines(string logFile, long pos, int done, int total)
    {
        if (!System.IO.File.Exists(logFile)) return (pos, done);

        try
        {
            using var fs = new System.IO.FileStream(logFile,
                System.IO.FileMode.Open, System.IO.FileAccess.Read, System.IO.FileShare.ReadWrite);
            fs.Seek(pos, System.IO.SeekOrigin.Begin);

            using var sr = new System.IO.StreamReader(fs, System.Text.Encoding.UTF8);
            string? line;
            while ((line = sr.ReadLine()) != null)
            {
                string trimmed = line.Trim();
                if (string.IsNullOrEmpty(trimmed)) { pos = fs.Position; continue; }

                if (trimmed.Contains("OK:") || trimmed.Contains("OK_DESINST:"))
                {
                    done++;
                    LogUI($"✅ {trimmed}");
                    SetBusy(true, $"Completadas {done}/{total}");
                }
                else if (trimmed.Contains("ERROR:") || trimmed.Contains("ERROR_DESINST:"))
                {
                    LogUI($"❌ {trimmed}");
                }
                else if (trimmed.Contains("BATCH_DONE"))
                {
                    LogUI("🎉 Todas las operaciones completadas.");
                }
                else
                {
                    LogUI(trimmed);
                    SetBusy(true, trimmed.Length > 80 ? trimmed[..80] + "…" : trimmed);
                }

                pos = fs.Position;
            }
        }
        catch { /* archivo puede estar bloqueado momentáneamente */ }

        return (pos, done);
    }

    // ─────────────────────────────────────────────
    //  LECTURA SIN ELEVACIÓN (para winget list)
    // ─────────────────────────────────────────────

    private async Task<string> RunWingetReadAsync(string arguments)
    {
        // Resolución robusta de winget.exe
        string wingetPath = FindWinget();
        if (string.IsNullOrEmpty(wingetPath))
        {
            LogUI("❌ winget.exe no encontrado. Instala App Installer desde la Microsoft Store.");
            return "error";
        }

        var psi = new System.Diagnostics.ProcessStartInfo
        {
            FileName = wingetPath,
            Arguments = arguments,
            UseShellExecute = false,
            CreateNoWindow = true,
            RedirectStandardOutput = true,
            RedirectStandardError = true,
            StandardOutputEncoding = System.Text.Encoding.UTF8,
            StandardErrorEncoding = System.Text.Encoding.UTF8
        };

        try
        {
            using var process = System.Diagnostics.Process.Start(psi);
            if (process == null) return "error";

            string stdout = await process.StandardOutput.ReadToEndAsync();
            string stderr = await process.StandardError.ReadToEndAsync();
            await process.WaitForExitAsync();

            return stdout + stderr;
        }
        catch (Exception ex)
        {
            LogUI($"❌ Error ejecutando winget: {ex.Message}");
            return "error";
        }
    }

    private static string FindWinget()
    {
        // 1. En PATH
        try
        {
            var r = System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
            {
                FileName = "where.exe",
                Arguments = "winget.exe",
                UseShellExecute = false,
                RedirectStandardOutput = true,
                CreateNoWindow = true
            });
            if (r != null)
            {
                string path = r.StandardOutput.ReadLine()?.Trim() ?? "";
                r.WaitForExit();
                if (System.IO.File.Exists(path)) return path;
            }
        }
        catch { }

        // 2. WindowsApps del usuario actual
        string localApp = System.IO.Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData),
            @"Microsoft\WindowsApps\winget.exe");
        if (System.IO.File.Exists(localApp)) return localApp;

        // 3. Buscar en WindowsApps (puede haber múltiples versiones)
        string windowsApps = System.IO.Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.ProgramFiles),
            "WindowsApps");
        if (System.IO.Directory.Exists(windowsApps))
        {
            try
            {
                var candidates = System.IO.Directory.GetFiles(
                    windowsApps, "winget.exe", System.IO.SearchOption.AllDirectories);
                if (candidates.Length > 0) return candidates[^1]; // última versión
            }
            catch { }
        }

        return string.Empty;
    }

