<Window
    x:Class="VisionaryOptimizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer"
    xmlns:viewmodels="using:VisionaryOptimizer.ViewModels"
    xmlns:models="using:VisionaryOptimizer.Models"
    xmlns:services="using:VisionaryOptimizer.Services"
    Title="Visionary Optimizer">

    <Window.SystemBackdrop>
        <MicaBackdrop /> 
    </Window.SystemBackdrop>

    <Grid Background="Transparent" x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. Barra de Título Exclusiva y Transparente (Integrada al entorno) -->
        <Grid x:Name="AppCustomTitleBar" Height="32" Background="Transparent">
            <!-- Icono y Nombre Aplicación -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="8" HorizontalAlignment="Left">
                <FontIcon Glyph="&#xE90C;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" />
                <TextBlock Text="Visionary Optimizer" FontSize="12" FontFamily="Segoe UI Variable" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- 2. Contenedor de Navegación -->
        <NavigationView Grid.Row="1" x:Name="NavView" PaneDisplayMode="Left" IsPaneOpen="True" IsPaneToggleButtonVisible="False" OpenPaneLength="240" CompactModeThresholdWidth="0" ExpandedModeThresholdWidth="0" IsBackButtonVisible="Collapsed" SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Inicio" Tag="home" ToolTipService.ToolTip="Panel Central">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Input Response" Tag="input">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE144;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Red Inteligente" Tag="network">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE701;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Servicios" Tag="services">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Power Strategy" Tag="power">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE945;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Limpieza Profunda" Tag="cleaner">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7FC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Instalador (Winget)" Tag="install">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <!-- CONTENIDO PRINCIPAL -->
                <ScrollViewer Padding="24" Background="Transparent">
                    <StackPanel Spacing="32" HorizontalAlignment="Stretch" VerticalAlignment="Top" MaxWidth="1200">
                        
                        <!-- Encabezado de Página Principal -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Visionary Optimizer 2026" FontSize="32" FontFamily="Segoe UI Variable Display" FontWeight="Bold"/>
                                <TextBlock Text="Sistema integral de ajuste de rendimiento." FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <!-- Panel de Estado Informativo en Vivo -->
                            <InfoBar Grid.Column="1" IsOpen="True" Severity="Informational" Title="Estado" Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" IsClosable="False" CornerRadius="8" />
                        </Grid>

                        <!-- INICIO / DASHBOARD -->
                        <StackPanel Spacing="32" Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionHome), Mode=OneWay}">
                            <Grid RowSpacing="16" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 1. EQUIPO -->
                                <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="🖥️" FontSize="18" />
                                            <TextBlock Text="INFORMACIÓN DEL EQUIPO" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Hostname:" FontWeight="SemiBold" FontSize="16" />
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.MachineName, Mode=OneWay}" FontSize="16" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Serial:" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.SerialNumber, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind ViewModel.SystemInfo.OsName, Mode=OneWay}" FontSize="14" Margin="0,4,0,0"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Versión:" FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.OsVersion, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Dominio:" FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{x:Bind ViewModel.SystemInfo.Domain, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 2. CPU -->
                                <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="🧠" FontSize="18" />
                                            <TextBlock Text="PROCESADOR (CPU)" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.SystemInfo.CpuModel, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind ViewModel.SystemInfo.CpuCoresText, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 3. DISCOS -->
                                <Border Grid.Row="2" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="💾" FontSize="18" />
                                            <TextBlock Text="ALMACENAMIENTO" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.SystemInfo.Disks, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="services:DiskInfoModel">
                                                    <TextBlock Text="{x:Bind DisplayText}" FontSize="14" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- 4. RAM -->
                                <Border Grid.Row="0" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="⚡" FontSize="18" />
                                            <TextBlock Text="MEMORIA RAM" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.SystemInfo.RamTotalText, Mode=OneWay}" FontSize="24" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 5. GPU -->
                                <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="🎮" FontSize="18" />
                                            <TextBlock Text="GRÁFICOS (GPU)" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.SystemInfo.GpuModel, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 6. RED -->
                                <Border Grid.Row="2" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="🌐" FontSize="18" />
                                            <TextBlock Text="REDES (MAC Address)" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.SystemInfo.MacAddresses, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="services:NetworkMacModel">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
                                                        <TextBlock Text="MAC:" FontWeight="SemiBold" FontSize="14" />
                                                        <TextBlock Text="{x:Bind DisplayText}" FontSize="14" TextWrapping="Wrap" FontFamily="Consolas"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- SECCIÓN INPUT (RATÓN/TECLADO) -->
                        <StackPanel Spacing="16" Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionInput), Mode=OneWay}">
                            <TextBlock Text="Input Response" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="Reducción extrema de latencia en periféricos. Los siguientes cambios se escribirán en el registro:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Estado en Tiempo Real" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Text="{x:Bind ViewModel.InputStateText, Mode=OneWay}" FontSize="14" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    
                                    <CheckBox Content="✓ SELECCIONAR TODO" IsChecked="{x:Bind ViewModel.SelectAllInput, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="APLICAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Input" />
                                        <Button Grid.Column="1" Content="REVERTIR SELECCIONADOS" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="Input" />
                                        <Button Grid.Column="2" Content="REVERTIR TODO (FÁBRICA)" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="Input" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.InputTweakItems, Mode=OneWay}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:TweakItemViewModel">
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind Description}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- SECCIÓN RED Y TCP -->
                        <StackPanel Spacing="16" Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionNetwork), Mode=OneWay}">
                            <TextBlock Text="Red Inteligente y TCP" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="Se eliminará la sobrecarga de TCP para priorizar el ping en aplicaciones en tiempo real." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Estado en Tiempo Real" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Text="{x:Bind ViewModel.NetworkStateText, Mode=OneWay}" FontSize="14" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    
                                    <CheckBox Content="✓ SELECCIONAR TODO" IsChecked="{x:Bind ViewModel.SelectAllNetwork, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="APLICAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Network" />
                                        <Button Grid.Column="1" Content="REVERTIR SELECCIONADOS" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="Network" />
                                        <Button Grid.Column="2" Content="REVERTIR TODO (FÁBRICA)" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="Network" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.NetworkTweakItems, Mode=OneWay}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:TweakItemViewModel">
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind Description}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- SECCIÓN SERVICIOS -->
                        <StackPanel Spacing="16" Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionServices), Mode=OneWay}">
                            <TextBlock Text="Servicios" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="Desactiva los procesos en segundo plano innecesarios (los críticos están bloqueados si usas Wi-Fi)." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Modularidad: Servicios" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Text="En lugar de aplicar todo globalmente, puedes mutar solo los servicios elegidos y restaurarlos aquí." FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <CheckBox Content="✓ SELECCIONAR TODO" IsChecked="{x:Bind ViewModel.SelectAllServices, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="APLICAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Services" />
                                        <Button Grid.Column="1" Content="REVERTIR SELECCIONADOS" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="Services" />
                                        <Button Grid.Column="2" Content="REVERTIR TODO (FÁBRICA)" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="Services" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.ServiceTweakItems, Mode=OneWay}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:ServiceTweakModel">
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" IsEnabled="{x:Bind IsToggleEnabled, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                
                                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind Description}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                                                    <TextBlock Text="⚠️ Protegido por conexión Wi-Fi actual" Visibility="{x:Bind IsWifiLockedVisibility, Mode=OneWay}" Foreground="#FF9900" FontSize="12" FontWeight="Medium" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- SECCIÓN ENERGÍA (POWER STRATEGY) -->
                        <StackPanel Spacing="16" Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionPower), Mode=OneWay}">
                            <TextBlock Text="Power Strategy (Energía)" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.PowerPlanDescription, Mode=OneWay}" TextWrapping="Wrap" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Carga individual de estado" FontWeight="SemiBold" FontSize="16" />

                                    <CheckBox Content="✓ SELECCIONAR TODO" IsChecked="{x:Bind ViewModel.SelectAllPower, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                    <Grid ColumnSpacing="12" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="APLICAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Power" />
                                        <Button Grid.Column="1" Content="REVERTIR SELECCIONADOS" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertSelectedModuleCommand}" CommandParameter="Power" />
                                        <Button Grid.Column="2" Content="REVERTIR TODO (FÁBRICA)" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.RevertAllModuleCommand}" CommandParameter="Power" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.PowerTweakItems, Mode=OneWay}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:TweakItemViewModel">
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Description}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- SECCIÓN LIMPIEZA -->
                    <StackPanel Spacing="16" Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionCleaner), Mode=OneWay}">
                        <TextBlock Text="Limpieza Profunda" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="Elimina datos innecesarios y optimiza el sistema." FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Acciones de Limpieza" FontWeight="SemiBold" FontSize="16" />

                                <CheckBox Content="✓ SELECCIONAR TODO" IsChecked="{x:Bind ViewModel.SelectAllCleaner, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,8,0,0"/>

                                <Grid ColumnSpacing="12" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="LIMPIAR SELECCIONADOS" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.ApplySelectedModuleCommand}" CommandParameter="Cleaner" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{x:Bind ViewModel.CleanerTweakItems, Mode=OneWay}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:CleanerTweakModel">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Description}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                                                <!-- Advertencia Roja Crítica -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind IsDangerVisibility, Mode=OneWay}" Margin="0,8,0,0" Background="#1A110000" Padding="8" CornerRadius="4">
                                                    <FontIcon Glyph="&#xE7BA;" Foreground="#FF3333" FontSize="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="¡ADVERTENCIA EXTREMA! ESTA ACCIÓN ELIMINARÁ TUS CARPETAS Y ARCHIVOS PERSONALES PERMANENTEMENTE." FontWeight="Bold" Foreground="#FF3333" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- SECCIÓN INSTALADOR WINGET -->
                    <Grid Visibility="{x:Bind BoolToVisibility(ViewModel.IsSectionInstall), Mode=OneWay}" RowSpacing="16" Height="700">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Gestor de Aplicaciones (Winget)" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="Instala, actualiza o desinstala software silenciosamente." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.InstallerVM.InstallerCategories}" SelectedItem="{x:Bind ViewModel.InstallerVM.InstallerSelectedCategory, Mode=TwoWay}" Header="Categoría"/>
                            <TextBox Grid.Column="1" HorizontalAlignment="Stretch" PlaceholderText="Buscar programa..." Text="{x:Bind ViewModel.InstallerVM.InstallerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Búsqueda"/>
                            <Button Grid.Column="2" Content="Detectar Instalados" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.InstallerVM.DetectInstalledAppsCommand}"/>
                        </Grid>

                        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="0">
                            <ListView ItemsSource="{x:Bind ViewModel.InstallerVM.FilteredAppItems, Mode=OneWay}" SelectionMode="None">
                                <ListView.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Text="Nombre de la App" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Grid.Column="2" Text="Winget ID" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="3" Text="Estado" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.HeaderTemplate>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:AppItem">
                                        <Grid Padding="12,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind WingetId}" VerticalAlignment="Center" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
                                                <FontIcon Glyph="&#xE73E;" Visibility="{x:Bind IsInstalled, Mode=OneWay}" Foreground="#00CC00" FontSize="16"/>
                                                <TextBlock Text="Instalado" Visibility="{x:Bind IsInstalled, Mode=OneWay}" Foreground="#00CC00" FontWeight="SemiBold"/>
                                                <TextBlock Text="No instalado" Visibility="{x:Bind InvertBool(IsInstalled), Mode=OneWay}" Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Grid Grid.Row="3" ColumnSpacing="12" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Instalar Seleccionados" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.InstallerVM.InstallSelectedAppsCommand}"/>
                            <Button Grid.Column="1" Content="Desinstalar Seleccionados" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.InstallerVM.UninstallSelectedAppsCommand}"/>
                            <Button Grid.Column="2" Content="Actualizar Todo" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.InstallerVM.UpdateAllAppsCommand}"/>
                        </Grid>

                        <Border Grid.Row="4" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" Padding="12" MinHeight="100" MaxHeight="140">
                            <ScrollViewer>
                                <TextBlock Text="{x:Bind ViewModel.InstallerVM.InstallLogs, Mode=OneWay}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </StackPanel>
                </ScrollViewer>

                <!-- CAPA FLOTANTE MIENTRAS OPTIMIZA (IS BUSY) -->
                <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" 
                      Opacity="0.9" 
                      Visibility="{x:Bind BoolToVisibility(ViewModel.IsBusy), Mode=OneWay}" 
                      Canvas.ZIndex="100">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="80" Height="80" />
                        <TextBlock Text="Inyectando optimizaciones en el sistema..." FontSize="20" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" />
                        <TextBlock Text="Por favor no cierres la ventana" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </NavigationView>
    </Grid>
</Window>
