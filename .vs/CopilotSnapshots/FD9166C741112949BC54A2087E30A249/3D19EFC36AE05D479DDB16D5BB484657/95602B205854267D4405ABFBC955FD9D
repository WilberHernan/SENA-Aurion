<Application
    x:Class="VisionaryOptimizer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- SENA BRAND COLOURS & THEMES -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#1A4D3E</Color>
                    <Color x:Key="SystemAccentColorDark1">#1B4332</Color>
                    <Color x:Key="SystemAccentColorDark2">#1B4332</Color>
                    <Color x:Key="SystemAccentColorDark3">#1B4332</Color>
                    <Color x:Key="SystemAccentColorLight1">#2D6A4F</Color>
                    <Color x:Key="SystemAccentColorLight2">#2D6A4F</Color>
                    <Color x:Key="SystemAccentColorLight3">#40916C</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#2D6A4F</Color>
                    <Color x:Key="SystemAccentColorLight1">#40916C</Color>
                    <Color x:Key="SystemAccentColorLight2">#52B788</Color>
                    <Color x:Key="SystemAccentColorLight3">#74C69D</Color>
                    <Color x:Key="SystemAccentColorDark1">#1A4D3E</Color>
                    <Color x:Key="SystemAccentColorDark2">#1B4332</Color>
                    <Color x:Key="SystemAccentColorDark3">#0D2A20</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- CUSTOM PREMIUM BRUSHES -->
            <SolidColorBrush x:Key="SenaPrimaryBrush" Color="#1A4D3E" />
            <SolidColorBrush x:Key="SenaSecondaryBrush" Color="#2D6A4F" />
            <SolidColorBrush x:Key="SenaAccentOpacityBrush" Color="#1A40916C" />
            <SolidColorBrush x:Key="SenaTextAccentBrush" Color="#74C69D" />
            
            <LinearGradientBrush x:Key="SenaButtonGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2D6A4F" Offset="0.0" />
                <GradientStop Color="#1A4D3E" Offset="1.0" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="GlassCardBackground" Color="#08FFFFFF" />
            
            <LinearGradientBrush x:Key="GlassCardBorder" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4D40916C" Offset="0.0" />
                <GradientStop Color="#1A40916C" Offset="0.5" />
                <GradientStop Color="#0040916C" Offset="1.0" />
            </LinearGradientBrush>
            
            <!-- STYLES -->
            
            <!-- Base Premium Card -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource GlassCardBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource GlassCardBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <!-- Home Dashboard Cards with Top Green Line -->
            <Style x:Key="HomeCardStyle" TargetType="Border" BasedOn="{StaticResource PremiumCardStyle}">
                <Setter Property="BorderThickness" Value="1,6,1,1" />
                <Setter Property="BorderBrush" Value="{StaticResource SenaSecondaryBrush}" />
            </Style>

            <!-- Primary Gradient Button -->
            <Style x:Key="PrimaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SenaButtonGradient}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="24,12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="100" CenterY="20" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary Outline Button -->
            <Style x:Key="SecondaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource SenaTextAccentBrush}" />
                <Setter Property="BorderBrush" Value="#40916C" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="24,12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="100" CenterY="20" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Text Formatting -->
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="{StaticResource SenaTextAccentBrush}" />
                <Setter Property="CharacterSpacing" Value="30" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
