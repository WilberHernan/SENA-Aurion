using System;
using Microsoft.UI.Xaml;
using Microsoft.UI.Xaml.Controls;
using Microsoft.UI.Xaml.Data;
using VisionaryOptimizer.Services;
using VisionaryOptimizer.ViewModels;

namespace VisionaryOptimizer;

public sealed partial class MainWindow : Window
{
    public MainViewModel ViewModel { get; }

    public MainWindow()
    {
        var log = new FileOptimizationLogger();
        var registry = new RegistryService(log);
        var services = new WindowsServiceOptimizer(log);
        var engine = new OptimizationEngine(log, registry, services);
        var provider = new JsonOptimizationDataProvider();

        ViewModel = new MainViewModel(provider, engine);

        this.InitializeComponent();

        // 1. Integración de la Barra de Título moderna (Windows 11+)
        ExtendsContentIntoTitleBar = true;
        SetTitleBar(AppCustomTitleBar);

        // 2. Selección automática de la primera pestaña al abrir
        if (NavView != null && NavView.MenuItems.Count > 0)
        {
            NavView.SelectedItem = NavView.MenuItems[0];
        }
    }

    private void NavView_SelectionChanged(NavigationView sender, NavigationViewSelectionChangedEventArgs args)
    {
        if (args.SelectedItem is NavigationViewItem item && item.Tag is string tag)
        {
            ViewModel.SelectedTag = tag;
            if (MainScroll != null)
            {
                MainScroll.ChangeView(null, 0, null, true);
                TopBlurBarrier.Opacity = 0;
                BottomBlurBarrier.Opacity = 1;
            }
        }
    }

    private void MainScroll_ViewChanged(ScrollViewer sender, ScrollViewerViewChangedEventArgs args)
    {
        // 1. Efecto Scroll Desenfoque Premium (Alpha masks for top and bottom)
        double current = sender.VerticalOffset;
        double max = sender.ScrollableHeight;

        if (max > 0)
        {
            // Aparecer suavemente el blur superior cuando bajamos
            TopBlurBarrier.Opacity = Math.Min(1.0, current / 60.0);
            
            // Desaparecer suavemente el blur inferior al llegar al final
            BottomBlurBarrier.Opacity = Math.Clamp((max - current) / 60.0, 0.0, 1.0);
        }
        else
        {
            TopBlurBarrier.Opacity = 0;
            BottomBlurBarrier.Opacity = 0; // Sin scroll no hay desenfoques limitantes
        }
    }

    private void Card_PointerEntered(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Border b)
        {
            b.Background = Application.Current.Resources["GlassCardHoverBackground"] as Microsoft.UI.Xaml.Media.Brush;
            b.BorderBrush = Application.Current.Resources["SenaSecondaryBrush"] as Microsoft.UI.Xaml.Media.Brush;
            b.BorderThickness = new Thickness(1);
        }
    }

    private void Card_PointerExited(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Border b)
        {
            // Revertir a estilo Glass dependiendo si era HomeCard o Premium Normal
            bool isHome = b.BorderThickness.Top > 2; // Hack visual to detect the 6px top line
            
            b.Background = Application.Current.Resources["GlassCardBackground"] as Microsoft.UI.Xaml.Media.Brush;
            if(!isHome)
            {
               b.BorderBrush = Application.Current.Resources["GlassCardBorder"] as Microsoft.UI.Xaml.Media.Brush;
            }
        }
    }

    private void Btn_PointerEntered(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Button btn && btn.RenderTransform is Microsoft.UI.Xaml.Media.ScaleTransform trans)
        {
            btn.Background = Application.Current.Resources["SenaHoverButtonGradient"] as Microsoft.UI.Xaml.Media.Brush;
            trans.ScaleX = 1.01;
            trans.ScaleY = 1.01;
        }
    }

    private void Btn_PointerExited(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Button btn && btn.RenderTransform is Microsoft.UI.Xaml.Media.ScaleTransform trans)
        {
            btn.Background = Application.Current.Resources["SenaButtonGradient"] as Microsoft.UI.Xaml.Media.Brush;
            trans.ScaleX = 1.0;
            trans.ScaleY = 1.0;
        }
    }

    private void BtnSecondary_PointerEntered(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Button btn && btn.RenderTransform is Microsoft.UI.Xaml.Media.ScaleTransform trans)
        {
            btn.Background = Application.Current.Resources["SenaAccentOpacityBrush"] as Microsoft.UI.Xaml.Media.Brush;
            trans.ScaleX = 1.01;
            trans.ScaleY = 1.01;
        }
    }

    private void BtnSecondary_PointerExited(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Button btn && btn.RenderTransform is Microsoft.UI.Xaml.Media.ScaleTransform trans)
        {
            btn.Background = new Microsoft.UI.Xaml.Media.SolidColorBrush(Microsoft.UI.Colors.Transparent);
            trans.ScaleX = 1.0;
            trans.ScaleY = 1.0;
        }
    }

    private void Btn_PointerPressed(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Button btn && btn.RenderTransform is Microsoft.UI.Xaml.Media.ScaleTransform trans)
        {
            trans.ScaleX = 0.98;
            trans.ScaleY = 0.98;
        }
    }

    private void Btn_PointerReleased(object sender, Microsoft.UI.Xaml.Input.PointerRoutedEventArgs e)
    {
        if (sender is Button btn && btn.RenderTransform is Microsoft.UI.Xaml.Media.ScaleTransform trans)
        {
            trans.ScaleX = 1.01;
            trans.ScaleY = 1.01;
        }
    }

    // Convertidor directo de función para x:Bind en la ventana (más rápido y seguro en WinUI 3 para objetos Window)
    public Visibility BoolToVisibility(bool isVisible) => isVisible ? Visibility.Visible : Visibility.Collapsed;
}
