<Application
    x:Class="VisionaryOptimizer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- SENA BRAND COLOURS & THEMES -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#2E8B57</Color>
                    <Color x:Key="SystemAccentColorDark1">#1B5E20</Color>
                    <Color x:Key="SystemAccentColorDark2">#1B5E20</Color>
                    <Color x:Key="SystemAccentColorDark3">#1B5E20</Color>
                    <Color x:Key="SystemAccentColorLight1">#4CAF50</Color>
                    <Color x:Key="SystemAccentColorLight2">#4CAF50</Color>
                    <Color x:Key="SystemAccentColorLight3">#E8F5E9</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#4CAF50</Color>
                    <Color x:Key="SystemAccentColorLight1">#2E8B57</Color>
                    <Color x:Key="SystemAccentColorLight2">#2E8B57</Color>
                    <Color x:Key="SystemAccentColorLight3">#2E8B57</Color>
                    <Color x:Key="SystemAccentColorDark1">#1B5E20</Color>
                    <Color x:Key="SystemAccentColorDark2">#1B5E20</Color>
                    <Color x:Key="SystemAccentColorDark3">#1B5E20</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- CUSTOM PREMIUM BRUSHES -->
            <SolidColorBrush x:Key="SenaPrimaryBrush" Color="#2E8B57" />
            <SolidColorBrush x:Key="SenaDarkBrush" Color="#1B5E20" />
            <SolidColorBrush x:Key="SenaAccentOpacityBrush" Color="#1A4CAF50" />
            
            <LinearGradientBrush x:Key="SenaButtonGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4CAF50" Offset="0.0" />
                <GradientStop Color="#2E7D32" Offset="1.0" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="GlassCardBackground" Color="#0CFFFFFF" />
            <SolidColorBrush x:Key="GlassCardBorder" Color="#262E8B57" /> 
            
            <!-- STYLES -->
            
            <!-- Base Premium Card -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource GlassCardBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource GlassCardBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <!-- Home Dashboard Cards with Top Green Line -->
            <Style x:Key="HomeCardStyle" TargetType="Border" BasedOn="{StaticResource PremiumCardStyle}>
                <Setter Property="BorderThickness" Value="1,4,1,1" />
                <Setter Property="BorderBrush" Value="{StaticResource SenaPrimaryBrush}" />
            </Style>

            <!-- Primary Gradient Button -->
            <Style x:Key="PrimaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SenaButtonGradient}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="24,12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Transitions">
                    <Setter.Value>
                        <TransitionCollection>
                            <ThemeTransition />
                        </TransitionCollection>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary Outline Button -->
            <Style x:Key="SecondaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#4CAF50" />
                <Setter Property="BorderBrush" Value="#4CAF50" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="24,12" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Text Formatting -->
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="#4CAF50" />
                <Setter Property="CharacterSpacing" Value="50" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
