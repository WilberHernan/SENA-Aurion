<Application
    x:Class="VisionaryOptimizer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VisionaryOptimizer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- SENA BRAND COLOURS & THEMES -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#20855A</Color>
                    <Color x:Key="SystemAccentColorDark1">#165E3D</Color>
                    <Color x:Key="SystemAccentColorDark2">#165E3D</Color>
                    <Color x:Key="SystemAccentColorDark3">#165E3D</Color>
                    <Color x:Key="SystemAccentColorLight1">#2BB57A</Color>
                    <Color x:Key="SystemAccentColorLight2">#2BB57A</Color>
                    <Color x:Key="SystemAccentColorLight3">#40D69A</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#2BB57A</Color>
                    <Color x:Key="SystemAccentColorLight1">#40D69A</Color>
                    <Color x:Key="SystemAccentColorLight2">#5AE0AE</Color>
                    <Color x:Key="SystemAccentColorLight3">#BDEBD0</Color>
                    <Color x:Key="SystemAccentColorDark1">#20855A</Color>
                    <Color x:Key="SystemAccentColorDark2">#165E3D</Color>
                    <Color x:Key="SystemAccentColorDark3">#0E3D27</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- CUSTOM PREMIUM BRUSHES & FONTS -->
            
            <!-- Local Custom Fonts mapping (requires adding the .ttf files to Assets\Fonts\) -->
            <FontFamily x:Key="InterFont">ms-appx:///Assets/Fonts/Inter/Inter-VariableFont_slnt,wght.ttf#Inter</FontFamily>
            <FontFamily x:Key="MontserratFont">ms-appx:///Assets/Fonts/Montserrat/Montserrat-VariableFont_wght.ttf#Montserrat</FontFamily>

            <SolidColorBrush x:Key="SenaPrimaryBrush" Color="#20855A" />
            <SolidColorBrush x:Key="SenaSecondaryBrush" Color="#2BB57A" />
            <SolidColorBrush x:Key="SenaAccentOpacityBrush" Color="#1A20855A" />
            <SolidColorBrush x:Key="SenaTextAccentBrush" Color="#5AE0AE" />
            <SolidColorBrush x:Key="SenaWarningBrush" Color="#FF6B6B" />
            
            <LinearGradientBrush x:Key="SenaButtonGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2BB57A" Offset="0.0" />
                <GradientStop Color="#20855A" Offset="1.0" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="SenaHoverButtonGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#40D69A" Offset="0.0" />
                <GradientStop Color="#2BB57A" Offset="1.0" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="GlassCardBackground" Color="#1420855A" />
            <SolidColorBrush x:Key="GlassCardHoverBackground" Color="#2620855A" />
            
            <LinearGradientBrush x:Key="GlassCardBorder" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#335AE0AE" Offset="0.0" />
                <GradientStop Color="#1120855A" Offset="0.5" />
                <GradientStop Color="#0020855A" Offset="1.0" />
            </LinearGradientBrush>
            
            <!-- STYLES -->
            
            <!-- Base Premium Card -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource GlassCardBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource GlassCardBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <!-- Home Dashboard Cards with Top Green Line -->
            <Style x:Key="HomeCardStyle" TargetType="Border" BasedOn="{StaticResource PremiumCardStyle}">
                <Setter Property="BorderThickness" Value="1,6,1,1" />
                <Setter Property="BorderBrush" Value="{StaticResource SenaSecondaryBrush}" />
            </Style>

            <!-- Primary Gradient Button -->
            <Style x:Key="PrimaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SenaButtonGradient}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="24,12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="100" CenterY="20" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary Outline Button -->
            <Style x:Key="SecondaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource SenaTextAccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource SenaSecondaryBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="24,12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="100" CenterY="20" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Text Formatting -->
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
                <Setter Property="Foreground" Value="{StaticResource SenaTextAccentBrush}" />
                <Setter Property="CharacterSpacing" Value="0" />
            </Style>

            <!-- Page Title Formatting -->
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontFamily" Value="{StaticResource MontserratFont}" />
                <Setter Property="Foreground" Value="#E8F5E9" />
                <Setter Property="CharacterSpacing" Value="50" /> <!-- ~2px in WinUI terms -->
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
