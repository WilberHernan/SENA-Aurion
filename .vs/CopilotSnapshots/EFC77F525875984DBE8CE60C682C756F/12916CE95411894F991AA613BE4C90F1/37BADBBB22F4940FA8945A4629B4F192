        if (Data is null) return;
        IsBusy = true;
        StatusMessage = $"Revirtiendo {moduleName} seleccionados…";
        try
        {
            switch (moduleName)
            {
                case "Input":
                    await _engine.RevertTweaksAsync(InputTweakItems.Where(t => t.IsSelected).Select(t => t.Definition), cancellationToken);
                    break;
                case "Network":
                    await _engine.RevertTweaksAsync(NetworkTweakItems.Where(t => t.IsSelected).Select(t => t.Definition), cancellationToken);
                    break;
                case "Services":
                    await _engine.RevertServicesAsync(ServiceTweakItems.Where(t => t.IsSelected).Select(t => t.Definition), cancellationToken);
                    break;
                case "Power":
                    if (PowerTweakItems.FirstOrDefault()?.IsSelected == true)
                        await _engine.RevertPowerPlanAsync(cancellationToken);
                    break;
            }
            StatusMessage = $"{moduleName} revertido.";
            RefreshAllModulesStates();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    [RelayCommand]
    private async Task RevertAllModuleAsync(string moduleName, CancellationToken cancellationToken)
    {
        if (Data is null) return;
        IsBusy = true;
        StatusMessage = $"Restaurando fábrica {moduleName}…";
        try
        {
            switch (moduleName)
            {
                case "Input":
                    await _engine.RevertTweaksAsync(InputTweakItems.Select(t => t.Definition), cancellationToken);
                    break;
                case "Network":
                    await _engine.RevertTweaksAsync(NetworkTweakItems.Select(t => t.Definition), cancellationToken);
                    break;
                case "Services":
                    await _engine.RevertServicesAsync(ServiceTweakItems.Select(t => t.Definition), cancellationToken);
                    break;
                case "Power":
                    await _engine.RevertPowerPlanAsync(cancellationToken);
                    break;
            }
            StatusMessage = $"{moduleName} restaurado.";
            RefreshAllModulesStates();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void RefreshAllTweakStates()
    {
        foreach(var t in InputTweakItems) t.RefreshState();
        foreach(var t in NetworkTweakItems) t.RefreshState();
        foreach(var t in ServiceTweakItems) t.RefreshState();
        foreach(var t in PowerTweakItems) t.RefreshState();
        foreach(var t in CleanerTweakItems) t.RefreshState();
    }

    [RelayCommand]
    public void RefreshAllModulesStates()
    {
        RefreshAllTweakStates();
        RefreshStates(); // For legacy real time texts properties
    }

    public Microsoft.UI.Xaml.Visibility InvertBool(bool val) => !val ? Microsoft.UI.Xaml.Visibility.Visible : Microsoft.UI.Xaml.Visibility.Collapsed;
