    [RelayCommand]
    private async Task DetectInstalledAppsAsync()
    {
        IsBusy = true;
        IsInstallIntermediate = true;
        InstallLogs = "Detectando aplicaciones instaladas mediante Winget...\n";

        try
        {
            var processInfo = new System.Diagnostics.ProcessStartInfo
            {
                FileName = "winget",
                Arguments = "list",
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                UseShellExecute = false,
                CreateNoWindow = true,
                StandardOutputEncoding = System.Text.Encoding.UTF8
            };

            using var process = System.Diagnostics.Process.Start(processInfo);
            if (process != null)
            {
                string output = await process.StandardOutput.ReadToEndAsync();

                foreach (var app in AllAppItems)
                {
                    // Basic detection check by winget ID in output
                    app.IsInstalled = output.Contains(app.WingetId, StringComparison.OrdinalIgnoreCase);
                }

                InstallLogs += "Detección completada.\n";
            }
        }
        catch (Exception ex)
        {
            InstallLogs += $"Error al detectar: {ex.Message}\n";
        }
        finally
        {
            IsBusy = false;
            IsInstallIntermediate = false;
        }
    }

    [RelayCommand]
    private async Task InstallSelectedAppsAsync()
    {
        var selected = AllAppItems.Where(a => a.IsSelected).ToList();
        if(!selected.Any()) return;

        IsBusy = true;
        IsInstallIntermediate = true;
        InstallLogs = "Comenzando instalación...\n";

        try
        {
            foreach(var app in selected)
            {
                InstallLogs += $"Instalando {app.Name}...\n";
                await RunWingetCommandAsync($"install --id {app.WingetId} --silent --accept-package-agreements --accept-source-agreements --force");
                app.IsInstalled = true; // Assume success or run detection
                InstallLogs += $"{app.Name} procesado.\n";
            }
            InstallLogs += "Operación finalizada.\n";
        }
        finally
        {
            IsBusy = false;
            IsInstallIntermediate = false;
            await DetectInstalledAppsAsync(); // Refresh
        }
    }

