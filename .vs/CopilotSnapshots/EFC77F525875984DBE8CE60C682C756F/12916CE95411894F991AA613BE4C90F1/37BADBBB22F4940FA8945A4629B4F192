    private async Task RunWingetCommandAsync(string args)
    {
        try
        {
            // Not redirecting output if required Admin rights are strict, but standard winget can be run without shell 
            // and simply prompts if admin is strictly needed by installer
            var processInfo = new System.Diagnostics.ProcessStartInfo
            {
                FileName = "winget",
                Arguments = args,
                UseShellExecute = false,
                CreateNoWindow = true,
                RedirectStandardOutput = true
            };

            using var process = System.Diagnostics.Process.Start(processInfo);
            if (process != null)
            {
                // Leer un poco de estado si es posible
                var readTask = process.StandardOutput.ReadToEndAsync();
                await process.WaitForExitAsync();
                var outp = await readTask;
                // Add short snipped to logs to avoid clutter
                if (!string.IsNullOrWhiteSpace(outp))
                    InstallLogs += $"\tWinget: ExitCode {process.ExitCode}\n";
            }
        }
        catch (Exception ex)
        {
            InstallLogs += $"[Error de Winget] {ex.Message}\n";
        }
    }

