<Window
    x:Class="SenaAurion.Shell.MainShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SenaAurion"
    xmlns:viewmodels="using:SenaAurion.ViewModels"
    xmlns:models="using:SenaAurion.Models"
    xmlns:services="using:SenaAurion.Services"
    xmlns:controls="using:SenaAurion.Controls"
    Title="SENA AURION">

    <Grid x:Name="HostRoot">
        <Image Source="ms-appx:///Assets/Images/bg_splash.jpg" Stretch="UniformToFill" HorizontalAlignment="Right" />
        <Grid HorizontalAlignment="Left" Width="700" IsHitTestVisible="False">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF050C07" Offset="0.0" />
                    <GradientStop Color="#CC050C07" Offset="0.6" />
                    <GradientStop Color="#00050C07" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <Grid x:Name="DashboardRoot" MinWidth="600" MinHeight="500" Padding="8" ColumnSpacing="8" Background="Transparent" Visibility="Collapsed">
            <Grid.Resources>
            <AcrylicBrush x:Key="GlassSurfaceBrush" TintColor="#111111" TintOpacity="0.28" FallbackColor="#AA141414"/>
            <SolidColorBrush x:Key="NeoRaisedBrush" Color="#232323"/>
            <SolidColorBrush x:Key="NeoShadowDarkBrush" Color="#AA000000"/>
            <SolidColorBrush x:Key="NeoShadowLightBrush" Color="#22FFFFFF"/>

            <Style x:Key="NeoActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#1AFFFFFF" />
                <Setter Property="Foreground" Value="#EEEEEE" />
                <Setter Property="BorderBrush" Value="#33FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="ModuleProgressRingStyle" TargetType="ProgressRing">
                <Setter Property="Width" Value="20" />
                <Setter Property="Height" Value="20" />
                <Setter Property="IsActive" Value="True" />
                <Setter Property="Foreground" Value="#E6FFFFFF" />
            </Style>
            <!-- Estilos MonocromÃ¡ticos Premium Dark -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="HomeCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Style x:Key="BodyMutedStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#66FFFFFF" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style x:Key="PrimaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="#2A2A2A" />
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            <Style x:Key="SecondaryPremiumButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="BorderBrush" Value="#1AFFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            
            <!-- Para no crear nuevos estilos complejos y mantener funcionalidad,
                 el texto accent de SENA lo ponemos monocromÃ¡tico aquÃ­. -->
            <SolidColorBrush x:Key="SenaTextAccentBrush" Color="#FFFFFF" />
            </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="56" /> <!-- Sidebar NavegaciÃ³n -->
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <!-- BARRA SUPERIOR OCULTA (Usada solo para arrastrar la ventana) -->
            <Grid x:Name="AppCustomTitleBar" VerticalAlignment="Top" Background="Transparent" Height="46" Margin="64,0,0,0" Canvas.ZIndex="20" />

            <!-- AREA DE CONTENIDO (Expandida al máximo) -->
            <Grid Margin="0,0,0,0">
                <Border Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid x:Name="MainContainerContent">
                        <Button Width="36" Height="36" Style="{StaticResource NeoActionButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" Canvas.ZIndex="30" Click="BackToSplash_Click" ToolTipService.ToolTip="Volver al Splash">
                             <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#E6FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <Grid Margin="76,54,76,30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind ViewModel.CurrentModuleTitle, Mode=OneWay}"
                                           Style="{StaticResource PageTitleStyle}"
                                           VerticalAlignment="Center"
                                           Visibility="{x:Bind ViewModel.NonUninstallerModuleVisibility, Mode=OneWay}"/>

                                <!-- Uninstaller title with subtle chevron + filter flyout -->
                                <Button Grid.Column="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind ViewModel.UninstallerModuleVisibility, Mode=OneWay}">
                                    <Button.Flyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem Text="Programas Normales" Click="FilterNormalPrograms_Click" FontSize="12" Height="32"/>
                                            <MenuFlyoutItem Text="Aplicaciones del Sistema" Click="FilterIncludeSystemPrograms_Click" FontSize="12" Height="32"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="Desinstalador" Style="{StaticResource PageTitleStyle}" />
                                        <TextBlock Text="▾" FontSize="14" Foreground="#8CFFFFFF" Margin="0,1,0,0"/>
                                        <TextBlock Text="{x:Bind ViewModel.UninstallerFilterText, Mode=OneWay}" FontSize="11" Foreground="#66FFFFFF" Margin="6,4,0,0"/>
                                    </StackPanel>
                                </Button>

                                <!-- Search (only uninstaller). Moved to column 1 with margin -->
                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="32,0,0,0" Visibility="{x:Bind ViewModel.UninstallerModuleVisibility, Mode=OneWay}">

                                    <Border x:Name="SearchBoxHost"
                                            HorizontalAlignment="Left"
                                            CornerRadius="10"
                                            Background="#14FFFFFF"
                                            BorderBrush="#1AFFFFFF"
                                            BorderThickness="1"
                                            Height="34"
                                            Width="0"
                                            Opacity="0"
                                            Visibility="Collapsed"
                                            Margin="48,0,0,0"
                                            VerticalAlignment="Center">
                                        <Grid>
                                            <TextBox x:Name="SearchBox"
                                                     Text="{x:Bind ViewModel.UninstallerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="Buscar por nombre o editor..."
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Foreground="#E6FFFFFF"
                                                     FontSize="12"
                                                     Padding="10,6,34,6"
                                                     HorizontalAlignment="Stretch"/>
                                            <Button Style="{StaticResource NeoActionButtonStyle}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Width="34" Height="34" Padding="0" Margin="0"
                                                    HorizontalAlignment="Right"
                                                    Click="SearchToggleCloseButton_Click"
                                                    ToolTipService.ToolTip="Cerrar Búsqueda">
                                                <FontIcon Glyph="&#xE7A6;" FontSize="12" Foreground="#8CFFFFFF" />
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <Button x:Name="SearchToggleButton"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource NeoActionButtonStyle}"
                                            Width="40" Height="34" Padding="0"
                                            Click="SearchToggleButton_Click"
                                            ToolTipService.ToolTip="Buscar Programas">
                                        <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#E6FFFFFF" />
                                    </Button>
                                </Grid>

                                <Button Grid.Column="3" Style="{StaticResource NeoActionButtonStyle}" Width="40" Height="34" Padding="0"
                                        Command="{x:Bind ViewModel.ToggleSelectAllCurrentModuleCommand}" ToolTipService.ToolTip="Seleccionar todo / deseleccionar todo">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="14" Foreground="#E6FFFFFF" />
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1">
                                <ListView ItemsSource="{x:Bind ViewModel.CurrentModuleItems, Mode=OneWay}"
                                         SelectedItem="{x:Bind ViewModel.SelectedModuleItem, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionMode="Single"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollMode="Enabled">
                                    <ListView.Resources>
                                        <!-- Personalización de la ScrollBar (WinUI 3 Lightweight Styling) -->
                                        <SolidColorBrush x:Key="ScrollBarPanningThumbBackground" Color="#2AFFFFFF"/>
                                        <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="#4DFFFFFF"/>
                                        <SolidColorBrush x:Key="ScrollBarThumbBorderBrush" Color="Transparent"/>
                                    </ListView.Resources>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Margin" Value="0,2"/>
                                            <Setter Property="CornerRadius" Value="8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <ListViewItemPresenter
                                                            CornerRadius="8"
                                                            SelectedBackground="#1AFFFFFF"
                                                            PointerOverBackground="#0DFFFFFF"
                                                            PressedBackground="#08FFFFFF"
                                                            SelectedPointerOverBackground="#26FFFFFF"
                                                            SelectedPressedBackground="#1AFFFFFF"
                                                            ContentMargin="12,8"
                                                            HorizontalContentAlignment="Stretch"
                                                            VerticalContentAlignment="Center" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:TweakItemViewModel">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                          IsEnabled="{x:Bind IsSelectable, Mode=OneWay}"
                                                          VerticalAlignment="Center"/>

                                                <Image Grid.Column="1"
                                                       Width="20" Height="20"
                                                       Margin="2,0,2,0"
                                                       Source="{x:Bind IconSource, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       Stretch="UniformToFill"
                                                       Opacity="0.9"/>

                                                <StackPanel Grid.Column="2" Spacing="3">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock FontSize="14" Foreground="#F2FFFFFF" FontWeight="SemiBold">
                                                            <Run Text="{x:Bind DisplayNameMain, Mode=OneWay}"/>
                                                            <Run Text="{x:Bind BlockedSuffix, Mode=OneWay}" Foreground="#FF6B6B"/>
                                                        </TextBlock>
                                                        <TextBlock Text="⚠"
                                                                   FontSize="12"
                                                                   Foreground="#FFC56A"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{x:Bind DangerVisibility, Mode=OneWay}"
                                                                   ToolTipService.ToolTip="Acción sensible: requiere revisión manual."/>
                                                    </StackPanel>

                                                    <!-- Descripción corta (especialmente útil en Servicios) -->
                                                    <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                                               FontSize="11"
                                                               Foreground="#66FFFFFF"
                                                               TextWrapping="WrapWholeWords"
                                                               MaxLines="2"/>

                                                    <!-- Estado actual (una línea) -->
                                                    <TextBlock Text="{x:Bind CurrentStateText, Mode=OneWay}"
                                                               FontSize="11"
                                                               Foreground="#8CFFFFFF"
                                                               Margin="0,2,0,0"/>

                                                    <TextBlock Text="{x:Bind LastChangeText, Mode=OneWay}"
                                                               FontSize="11"
                                                               Foreground="#B3FFFFFF"
                                                               Visibility="{x:Bind LastChangeVisibility, Mode=OneWay}"/>
                                                </StackPanel>

                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- COLUMNA DERECHA SECUNDARIA -->
        <Grid Grid.Column="1" RowSpacing="8" Margin="0,24,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- CARD SUPERIOR: qué hace el módulo seleccionado -->
            <Border Grid.Row="0" Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.CurrentModuleTitle, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" Foreground="#F2FFFFFF" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentModuleDescription, Mode=OneWay}" FontSize="11" Foreground="#B3FFFFFF" LineHeight="17" Margin="0,8,0,0" TextWrapping="Wrap" />

                    <TextBlock Text="⚠️ Se recomienda ejecutar el programa como administrador para este módulo. Algunos procesos pueden presentar errores si no se cuentan con los permisos adecuados."
                               FontSize="11"
                               Foreground="#FF6B6B"
                               Margin="0,8,0,0"
                               TextWrapping="WrapWholeWords"
                               Visibility="{x:Bind ViewModel.UninstallerModuleVisibility, Mode=OneWay}"/>

                    <Grid Margin="0,12,0,0" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ProgressRing Grid.Column="0"
                                      Style="{StaticResource ModuleProgressRingStyle}"
                                      Visibility="{x:Bind ViewModel.CurrentModuleIsApplyingVisibility, Mode=OneWay}" />

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="{x:Bind ViewModel.CurrentModuleSummaryText, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="#8CFFFFFF"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentModuleLastResultText, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="#B3FFFFFF"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.CurrentModuleLastResultVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CARD INFERIOR -->
            <Border Grid.Row="1" Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" Padding="16">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="CleanerWarningText" Text="El módulo de limpieza elimina archivos de forma permanente." Foreground="#FF4D4D" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                    <StackPanel x:Name="DefaultActionsPanel">
                        <Button x:Name="PrimaryActionButton" Content="Aplicar" Click="PrimaryActionButton_Click" Style="{StaticResource NeoActionButtonStyle}" Margin="0,0,0,8"/>
                        <Button x:Name="SecondaryActionButton" Content="Revertir" Click="SecondaryActionButton_Click" Style="{StaticResource NeoActionButtonStyle}" Margin="0,0,0,8"/>
                        <Button x:Name="TertiaryActionButton" Content="Restaurar de fabrica" Click="TertiaryActionButton_Click" Style="{StaticResource NeoActionButtonStyle}"/>
                    </StackPanel>

                    <StackPanel x:Name="ProgramsActionsPanel" Visibility="Collapsed">
                        <Button Content="Instalar" Click="InstallProgramsButton_Click" Style="{StaticResource NeoActionButtonStyle}" Margin="0,0,0,8"/>
                        <Button Content="Actualizar" Click="UpdateProgramsButton_Click" Style="{StaticResource NeoActionButtonStyle}" Margin="0,0,0,8"/>
                        <Button Content="Desinstalar" Click="UninstallProgramsButton_Click" Style="{StaticResource NeoActionButtonStyle}"/>
                    </StackPanel>

                    <StackPanel x:Name="UninstallerActionsPanel" Visibility="Collapsed">
                        <Button Content="Desinstalar" Click="UninstallInstalledProgramsButton_Click" Style="{StaticResource NeoActionButtonStyle}" Margin="0,0,0,8"/>
                        <Button Content="Desinstalación avanzada" Click="AdvancedUninstallInstalledProgramsButton_Click" Style="{StaticResource NeoActionButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SIDEBAR DE NAVEGACIÃ“N -->
        <Border Grid.Column="2" Background="{StaticResource GlassSurfaceBrush}" CornerRadius="14" Margin="0,24,0,0">
            <Grid Padding="0,16">
                <!-- Ãconos de NavegaciÃ³n Verticalmente Centrados -->
                <StackPanel x:Name="NavBarStack" VerticalAlignment="Center" Spacing="16" HorizontalAlignment="Center">
                    <!-- Home -->
                    <Button Click="TabButton_Click" CommandParameter="home" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="18" Width="38" Height="38" ToolTipService.ToolTip="Inicio">
                        <Grid>
                            <Border Width="38" Height="38" CornerRadius="19" Background="#2C2C2C" />
                            <FontIcon Glyph="&#xE80F;" FontSize="16" Foreground="#B3FFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Input -->
                    <Button Click="TabButton_Click" CommandParameter="input" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="18" Width="38" Height="38" ToolTipService.ToolTip="Entrada">
                        <Grid>
                            <Border Width="38" Height="38" CornerRadius="19" Background="Transparent" />
                            <FontIcon Glyph="&#xE144;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Network -->
                    <Button Click="TabButton_Click" CommandParameter="network" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="18" Width="38" Height="38" ToolTipService.ToolTip="Red">
                        <Grid>
                            <Border Width="38" Height="38" CornerRadius="19" Background="Transparent" />
                            <FontIcon Glyph="&#xE701;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                    
                    <!-- Servicios -->
                    <Button Click="TabButton_Click" CommandParameter="services" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="18" Width="38" Height="38" ToolTipService.ToolTip="Servicios">
                        <Grid>
                            <Border Width="38" Height="38" CornerRadius="19" Background="Transparent" />
                            <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <!-- Cleaner -->
                    <Button Click="TabButton_Click" CommandParameter="cleaner" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="18" Width="38" Height="38" ToolTipService.ToolTip="Limpieza">
                        <Grid>
                            <Border Width="38" Height="38" CornerRadius="19" Background="Transparent" />
                            <FontIcon Glyph="&#xE7FC;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <Button Click="TabButton_Click" CommandParameter="programs" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="18" Width="38" Height="38" ToolTipService.ToolTip="Programas">
                        <Grid>
                            <Border Width="38" Height="38" CornerRadius="19" Background="Transparent" />
                            <FontIcon Glyph="&#xEA37;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>

                    <Button Click="TabButton_Click" CommandParameter="uninstaller" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="18" Width="38" Height="38" ToolTipService.ToolTip="Desinstalador">
                        <Grid>
                            <Border Width="38" Height="38" CornerRadius="19" Background="Transparent" />
                            <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="#4DFFFFFF" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        </Grid>

        <Grid x:Name="SplashRoot">
            <Grid.Resources>
                <AcrylicBrush x:Key="AcrylicGlassBrush" TintColor="#1A1A1A" TintOpacity="0.2" FallbackColor="#331A1A1A" />
                <Storyboard x:Name="ScrollAnimation" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="ScrollTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="14" Duration="0:0:0.9" AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>
            <Grid x:Name="UIContainer" RenderTransformOrigin="0.5,0.5">
                <Grid>
                    <Rectangle x:Name="AppTitleBar" Height="32" VerticalAlignment="Top" Fill="Transparent"/>
                    <Grid VerticalAlignment="Top" Padding="32,24,32,0" Margin="0,10,0,0">
                        <Path Data="M 18,0 L 36,9 L 36,27 L 18,36 L 0,27 L 0,9 Z M 18,7 A 11,11 0 1 0 18,29 A 11,11 0 1 0 18,7 Z"
                              Stroke="#1DB870" StrokeThickness="2" Fill="Transparent"
                              Width="36" Height="36" Stretch="Uniform"
                              HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Inicio" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="Version 17" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="Compilado" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                            <TextBlock Text="Creado" FontFamily="Segoe UI" FontWeight="Normal" FontSize="13" Foreground="#FFFFFF" Opacity="0.6" />
                        </StackPanel>
                        <Button Background="Transparent" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="20" Padding="8,7,8,7"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Click="TopButton_Click" Height="42">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Abrir panel" FontSize="12" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Grid Width="26" Height="26">
                                    <Path Data="M 4,10 L 16,10 M 10,4 L 16,10 L 10,16" Stroke="#FFFFFF" StrokeThickness="1.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="12" Height="12" />
                                </Grid>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,60,0,0">
                        <TextBlock Text="SENA&#x0a;AURION" FontFamily="Segoe UI" FontWeight="ExtraBold" FontSize="72" Foreground="#FFFFFF"
                                   CharacterSpacing="-120" LineStackingStrategy="BlockLineHeight" LineHeight="72" />
                        <TextBlock Text="Where innovation knows no bounds" FontFamily="Segoe UI" FontSize="14"
                                   Foreground="#FFFFFF" Opacity="0.45" Margin="0,10,0,0" CharacterSpacing="30" />
                    </StackPanel>
                    <Button Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28" Click="SpecsButton_Click">
                        <Grid Width="28" Height="44">
                            <Border BorderBrush="#33FFFFFF" BorderThickness="1.5" CornerRadius="14" Background="Transparent" />
                            <Rectangle x:Name="ScrollIndicator" Width="4" Height="10" Fill="#80FFFFFF" RadiusX="2" RadiusY="2" VerticalAlignment="Top" Margin="0,6,0,0">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="ScrollTransform" Y="0"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="32,0,0,32" Spacing="20">
                        <Image Source="ms-appx:///Assets/Images/facebook.png" Width="18" Height="18" Opacity="0.8" Stretch="Uniform" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid x:Name="SpecsModal" Visibility="Collapsed" Padding="24" PointerPressed="SpecsModal_PointerPressed">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent" />
                </Grid.Background>
                <Grid.RowDefinitions>
